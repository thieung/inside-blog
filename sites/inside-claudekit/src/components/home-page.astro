<!-- DIVIDER -->
<div class="section-divider"><span>{t.divider}</span></div>

<!-- POSTS -->
<main class="posts">
  <div class="no-results">{t.noResults}</div>
  <div class="posts-list">
    {posts.map(post => {
      const url = postUrl(post.slug);
      const Tag = url ? 'a' : 'div';
      return (
        <Tag class:list={['post-card', { 'is-upcoming': post.status === 'upcoming' }]} {...(url ? { href: url } : {})}>
          <div class="post-header">
            <span class={`post-status post-status--${post.status}`}>
              {t.status[post.status]}
            </span>
            <span class="post-date">{post.date}</span>
          </div>
          <div class="post-body">
            <div class="post-content">
              <div class="post-title">{post.title[locale]}</div>
              <p class="post-excerpt">{post.excerpt[locale]}</p>
              <div class="post-tags">
                {post.tags.map(tag => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            </div>
            {url && <div class="post-arrow">→</div>}
          </div>
        </Tag>
      );
    })}
  </div>
</main>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-left">
    <div class="footer-brand"><a href="https://claudekit.cc/?ref=OMG49S8R" target="_blank" rel="noopener noreferrer">ClaudeKit</a> — Engineer Kit for Claude Code</div>
    <div class="footer-note">{t.footerNote}</div>
  </div>
</footer>

<script>
// Search
const searchInput = document.querySelector('.search-input') as HTMLInputElement;
const postsList = document.querySelector('.posts-list') as HTMLElement;
const allCards = Array.from(postsList.querySelectorAll('.post-card')) as HTMLElement[];
const noResults = document.querySelector('.no-results') as HTMLElement;

searchInput.addEventListener('input', () => {
  const q = searchInput.value.toLowerCase().trim();
  let visible = 0;
  allCards.forEach(card => {
    const match = !q || (card.textContent?.toLowerCase() ?? '').includes(q);
    card.style.display = match ? '' : 'none';
    if (match) visible++;
  });
  noResults.style.display = visible === 0 ? 'block' : 'none';
});

// Theme toggle
const themeToggle = document.querySelector('.theme-toggle') as HTMLButtonElement;
const savedTheme = localStorage.getItem('claudekit-blog-theme');
if (savedTheme) document.documentElement.setAttribute('data-theme', savedTheme);

themeToggle.addEventListener('click', () => {
  const current = document.documentElement.getAttribute('data-theme');
  const next = current === 'light' ? 'dark' : 'light';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('claudekit-blog-theme', next);
});
</script>
</body>
</html>
