<script>
// Theme toggle - use addEventListener since Astro bundles scripts as modules
const themeBtn = document.getElementById('themeToggle');
themeBtn?.addEventListener('click', () => {
  const html = document.documentElement;
  const current = html.getAttribute('data-theme');
  const next = current === 'dark' ? 'light' : 'dark';
  html.setAttribute('data-theme', next);
  localStorage.setItem('theme', next);
});

// TOC active state
const tocLinks = document.querySelectorAll('.toc-link');
const sections = document.querySelectorAll('.section-band[id]');

function updateTOC() {
  let current = '';
  sections.forEach(section => {
    const rect = section.getBoundingClientRect();
    if (rect.top <= 100) current = section.id;
  });
  tocLinks.forEach(link => {
    link.classList.toggle('active', link.getAttribute('href') === '#' + current);
  });
}
window.addEventListener('scroll', updateTOC);
updateTOC();

// Lucide icons (inline SVG, stroke-based)
const ICON_COPY = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
const ICON_CHECK = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';

// Enhance all code blocks: traffic lights + copy button
document.querySelectorAll('.code-block').forEach(block => {
  const header = block.querySelector('.code-block__header');
  const body = block.querySelector('.code-block__body');
  if (!header || !body || header.dataset.enhanced === '1') return;
  const titleHTML = header.innerHTML;
  header.innerHTML =
    '<span class="code-block__dots"><span></span><span></span><span></span></span>' +
    '<span class="code-block__title">' + titleHTML + '</span>' +
    '<button class="code-block__copy" type="button" aria-label="Copy code to clipboard" title="Copy">' + ICON_COPY + '</button>';
  header.dataset.enhanced = '1';
  const copyBtn = header.querySelector('.code-block__copy');
  copyBtn.addEventListener('click', () => {
    const text = body.textContent.trim();
    const done = () => {
      copyBtn.classList.add('copied');
      copyBtn.innerHTML = ICON_CHECK;
      copyBtn.setAttribute('title', 'Copied');
      setTimeout(() => {
        copyBtn.classList.remove('copied');
        copyBtn.innerHTML = ICON_COPY;
        copyBtn.setAttribute('title', 'Copy');
      }, 1800);
    };
    const fallback = () => {
      const ta = document.createElement('textarea');
      ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
      document.body.appendChild(ta); ta.select();
      try { if (document.execCommand('copy')) done(); } catch (e) {}
      document.body.removeChild(ta);
    };
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(done, fallback);
    } else {
      fallback();
    }
  });
});

// OS toggle (Project/Global anatomy)
document.querySelectorAll('.scope-anatomy').forEach(root => {
  root.querySelectorAll('.os-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.osTarget;
      root.dataset.os = target;
      root.querySelectorAll('.os-btn').forEach(b => {
        const active = b.dataset.osTarget === target;
        b.classList.toggle('active', active);
        b.setAttribute('aria-selected', active);
      });
    });
  });
});

// Installer path picker
(function initInstallerPicker() {
  const picker = document.getElementById('installer-picker');
  if (!picker) return;
  const cmdEl = document.getElementById('installer-cmd');
  const metaEl = document.getElementById('installer-meta');
  const copyBtn = document.getElementById('installer-copy');

  // Auto-detect platform on load
  const ua = (navigator.userAgent || '').toLowerCase();
  const isWin = ua.includes('win') && !ua.includes('linux') && !ua.includes('mac');
  if (isWin) {
    picker.dataset.platform = 'win';
    picker.querySelectorAll('.os-btn').forEach(b => {
      const active = b.dataset.platformTarget === 'win';
      b.classList.toggle('active', active);
      b.setAttribute('aria-selected', active);
    });
  }

  function escape(s) { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

  function render() {
    const project = picker.dataset.project;
    const scope = picker.dataset.scope;
    const mode = picker.dataset.mode;
    const channel = picker.dataset.channel;
    const fresh = picker.dataset.fresh;
    const platform = picker.dataset.platform;

    const isWin = platform === 'win';
    const prompt = isWin ? 'PS>' : '$';
    const lines = [];
    let installPath = '';
    let description = '';

    if (project === 'new') {
      lines.push('ck new --dir my-project --kit engineer');
      installPath = isWin ? '.\\my-project\\.claude\\' : './my-project/.claude/';
      description = 'Tạo folder <strong>my-project/</strong> mới, cài config vào <code>' + (isWin ? '.\\.claude\\' : './.claude/') + '</code> bên trong. Đổi <code>my-project</code> thành tên bạn muốn.';
    } else {
      lines.push('cd existing-project');
      const flags = ['--kit engineer'];
      if (scope === 'global') flags.unshift('-g');
      if (mode === 'auto') flags.push('--yes', '--install-skills');
      if (channel === 'beta') flags.push('--beta');
      if (fresh === 'yes') flags.push('--fresh');
      lines.push('ck init ' + flags.join(' '));
      if (scope === 'global') {
        installPath = isWin ? '%USERPROFILE%\\.claude\\' : '~/.claude/';
        description = 'Cài vào <code>' + installPath + '</code> (home directory) — config share giữa <strong>mọi project</strong> trên máy.';
      } else {
        installPath = isWin ? '.\\.claude\\' : './.claude/';
        description = 'Cài vào <code>' + installPath + '</code> trong project — config chỉ áp dụng cho <strong>project này</strong>.';
      }
    }

    cmdEl.innerHTML = lines.map(l =>
      '<span class="prompt">' + prompt + '</span><span class="cmd-line">' + escape(l) + '</span>'
    ).join('\n');
    cmdEl.dataset.plain = lines.join('\n');

    const modeText = mode === 'auto'
      ? '<strong>Auto mode:</strong> CLI skip mọi prompt + install toàn bộ skills catalog ngay lập tức.'
      : '<strong>Interactive mode:</strong> CLI sẽ hỏi từng option (skills, hooks, agents) — bạn chọn tick/untick.';
    const channelText = channel === 'beta' ? '<strong>Beta channel:</strong> release mới nhất, có thể có bug.' : '';
    const platformText = isWin ? '<strong>Windows:</strong> chạy trong PowerShell (default) hoặc CMD (Command Prompt). Windows Terminal/WSL cũng được — <code>ck</code> là Node CLI, shell-agnostic.' : '';
    const warnSvg = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:3px;"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>';
    const freshBlock = (project === 'existing' && fresh === 'yes')
      ? '<strong style="color: var(--amber);">' + warnSvg + 'Fresh reset:</strong> xoá CK files trong <code>.claude/</code> (agents, commands, skills, rules, hooks) + replace <code>settings.json</code>.'
        + '<ul style="margin: 4px 0 4px 18px; padding: 0; list-style: disc;">'
        + '<li><strong>Project-mode:</strong> <code>CLAUDE.md</code> ở root được preserve (user config).</li>'
        + '<li><strong>Global-mode (-g):</strong> <code>~/.claude/CLAUDE.md</code> bị replace.</li>'
        + '</ul>'
        + '<strong style="color: var(--amber);">Backup trước khi chạy.</strong>'
      : '';

    const folderIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:4px;color:var(--accent);"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>';
    const metaLines = [
      folderIcon + ' Install path: <code>' + installPath + '</code>',
      description,
      modeText,
      channelText,
      platformText,
      freshBlock
    ].filter(Boolean);
    metaEl.innerHTML = metaLines.join('<br>');
  }

  picker.querySelectorAll('.opt-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.key;
      const value = btn.dataset.value;
      picker.dataset[key] = value;
      picker.querySelectorAll('.opt-btn[data-key="' + key + '"]').forEach(b => {
        b.classList.toggle('active', b === btn);
      });
      render();
    });
  });

  // Platform (OS) toggle
  picker.querySelectorAll('.os-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.platformTarget;
      picker.dataset.platform = target;
      picker.querySelectorAll('.os-btn').forEach(b => {
        const active = b.dataset.platformTarget === target;
        b.classList.toggle('active', active);
        b.setAttribute('aria-selected', active);
      });
      render();
    });
  });

  copyBtn.innerHTML = ICON_COPY;
  copyBtn.addEventListener('click', () => {
    const text = cmdEl.dataset.plain || cmdEl.textContent;
    const done = () => {
      copyBtn.classList.add('copied');
      copyBtn.innerHTML = ICON_CHECK;
      copyBtn.setAttribute('title', 'Copied');
      setTimeout(() => {
        copyBtn.classList.remove('copied');
        copyBtn.innerHTML = ICON_COPY;
        copyBtn.setAttribute('title', 'Copy');
      }, 1800);
    };
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(done).catch(() => {
        const ta = document.createElement('textarea');
        ta.value = text; document.body.appendChild(ta); ta.select();
        try { document.execCommand('copy'); done(); } catch (e) {}
        document.body.removeChild(ta);
      });
    }
  });

  render();
})();
</script>
</body>
</html>
