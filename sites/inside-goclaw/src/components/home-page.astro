---
interface Props {
  locale: 'vi' | 'en' | 'zh' | 'ja';
}

const { locale } = Astro.props;

const translations = {
  vi: {
    heroTitle: 'Khám phá kiến trúc<br><em>nền tảng AI agent</em>',
    heroDesc: 'Phân tích trực quan các tính năng nổi bật của GoClaw — viết bởi người đóng góp, giúp người đọc hiểu kiến trúc đằng sau mỗi bản phát hành.',
    divider: 'Phân tích chuyên sâu',
    noResults: 'Không tìm thấy bài viết nào.',
    footerNote: 'Viết bởi người đóng góp. Không phải tài liệu chính thức.',
    search: 'Tìm kiếm...',
    htmlLang: 'vi',
  },
  en: {
    heroTitle: 'Deep dives into building<br><em>AI agent infrastructure</em>',
    heroDesc: "Visual deep dives into GoClaw's notable features — written by a contributor to help readers understand the architecture behind each release.",
    divider: 'Feature Deep Dives',
    noResults: 'No posts found.',
    footerNote: 'Written by a contributor. Not official documentation.',
    search: 'Search...',
    htmlLang: 'en',
  },
  zh: {
    heroTitle: '深入探索构建<br><em>AI Agent 基础设施</em>',
    heroDesc: 'GoClaw 重要功能的可视化深度分析 — 由贡献者撰写，帮助读者理解每次发布背后的架构。',
    divider: '深度解析',
    noResults: '未找到文章。',
    footerNote: '由贡献者撰写，非官方文档。',
    search: '搜索...',
    htmlLang: 'zh-CN',
  },
  ja: {
    heroTitle: 'AIエージェント基盤の<br><em>アーキテクチャ探求</em>',
    heroDesc: 'GoClaw の注目機能をビジュアルで深掘り — コントリビューターが各リリースの背後にあるアーキテクチャを解説。',
    divider: 'ディープダイブ',
    noResults: '記事が見つかりません。',
    footerNote: 'コントリビューターによる執筆。公式ドキュメントではありません。',
    search: '検索...',
    htmlLang: 'ja',
  },
};

const t = translations[locale];

interface Post {
  slug: string;
  version: string;
  date: string;
  tags: string[];
  title: Record<string, string>;
  excerpt: Record<string, string>;
}

const posts: Post[] = [
  {
    slug: 'mcp-hybrid-search-mode',
    version: 'v2.56.0',
    date: 'Apr 2, 2026',
    tags: ['mcp', 'hybrid-search', 'bm25', 'tool-management'],
    title: {
      vi: 'MCP Hybrid Search Mode — Quản lý tool thông minh',
      en: 'MCP Hybrid Search Mode — Smart Tool Management',
      zh: 'MCP 混合搜索模式 — 智能工具管理',
      ja: 'MCP ハイブリッド検索モード — スマートツール管理',
    },
    excerpt: {
      vi: 'Giữ 40 tool inline, defer phần còn lại qua BM25 — cơ chế quản lý tool thông minh khi số lượng MCP tool vượt ngưỡng.',
      en: 'Keep 40 tools inline, defer the rest via BM25 — smart tool management when MCP tool count exceeds the threshold.',
      zh: '保留 40 个工具内联，其余通过 BM25 延迟加载 — MCP 工具数超过阈值时的智能管理机制。',
      ja: '最初の40ツールをインラインに保持、残りをBM25で遅延読み込み — MCPツール数が閾値を超えたときのスマート管理。',
    },
  },
  {
    slug: 'force-directed-knowledge-graphs',
    version: 'v2.47.0',
    date: 'Mar 31, 2026',
    tags: ['knowledge-graph', 'hybrid-search', 'three.js'],
    title: {
      vi: 'Knowledge Graph — Từ hội thoại đến bộ nhớ ngữ nghĩa',
      en: 'Knowledge Graph — From Conversations to Semantic Memory',
      zh: 'Knowledge Graph — 从对话到语义记忆',
      ja: 'Knowledge Graph — 会話からセマンティックメモリへ',
    },
    excerpt: {
      vi: 'Phân tích chuyên sâu kiến trúc Knowledge Graph: trích xuất thực thể, tìm kiếm kết hợp, trực quan hoá 3D force-directed, và 10 tối ưu hiệu năng.',
      en: 'Deep dive into Knowledge Graph architecture: entity extraction, hybrid search, 3D force-directed visualization, and 10 performance optimizations.',
      zh: '知识图谱架构深度分析：实体提取、混合搜索、3D 力导向可视化和 10 项性能优化。',
      ja: 'Knowledge Graphアーキテクチャの詳細分析：エンティティ抽出、ハイブリッド検索、3Dフォースレイアウト可視化、10のパフォーマンス最適化。',
    },
  },
  {
    slug: 'codex-oauth-pools',
    version: 'v2.34.0',
    date: 'Mar 28, 2026',
    tags: ['oauth', 'credential-management', 'multi-tenant'],
    title: {
      vi: 'Codex OAuth Pools — Định tuyến token thông minh',
      en: 'Codex OAuth Pools — Smart Token Routing',
      zh: 'Codex OAuth Pools — 智能令牌路由',
      ja: 'Codex OAuth Pools — スマートトークンルーティング',
    },
    excerpt: {
      vi: 'Quản lý thông tin xác thực tập trung cho cổng AI đa người dùng. Định tuyến theo nhóm, tự động xoay vòng, chấm điểm sức khỏe và nhận biết giới hạn tốc độ.',
      en: 'Centralized credential management for multi-tenant AI gateway. Pool-based routing, auto-rotation, health scoring and rate limit awareness.',
      zh: '面向多租户 AI 网关的集中式凭证管理。基于池的路由、自动轮换、健康评分和速率限制感知。',
      ja: 'マルチテナントAIゲートウェイ向けの集中型認証情報管理。プールベースのルーティング、自動ローテーション、ヘルススコアリング。',
    },
  },
  {
    slug: 'yield-mention-mode',
    version: 'v2.24.0',
    date: 'Mar 27, 2026',
    tags: ['yield', 'mention-mode', 'group-chat'],
    title: {
      vi: 'Yield Mention Mode — Cơ chế nhường lượt thông minh',
      en: 'Yield Mention Mode — Smart Turn Yielding',
      zh: 'Yield Mention Mode — 智能让步模式',
      ja: 'Yield Mention Mode — スマートターン譲渡',
    },
    excerpt: {
      vi: 'Cơ chế nhường lượt thông minh trong nhóm chat. Agent tự động nhận biết khi nào cần im lặng và nhường cho agent khác trả lời.',
      en: 'Smart turn-yielding mechanism in group chats. Agents automatically recognize when to stay silent and let another agent respond.',
      zh: '群聊中的智能让步机制。Agent 自动识别何时保持沉默，让其他 Agent 回应。',
      ja: 'グループチャットでのスマートターン譲渡。エージェントが自動的に沈黙すべき時を認識し、他のエージェントに応答を譲ります。',
    },
  },
];

function postUrl(slug: string): string {
  return locale === 'vi' ? `/posts/${slug}` : `/${locale}/posts/${slug}`;
}
---
<!DOCTYPE html>
<html lang={t.htmlLang}>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>Inside GoClaw — Deep Dives into AI Agent Architecture</title>
<meta name="description" content="Visual deep dives into GoClaw's notable features — written by a contributor to help readers understand the architecture behind each release.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Outfit:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style is:global>
  :root {
    --bg: #1a1410;
    --surface: #231e18;
    --surface2: #2d2620;
    --surface3: #3a3028;
    --border: #4a3d30;
    --border-subtle: #2d2620;
    --text: #f0ebe4;
    --text-secondary: #c4b8a8;
    --text-muted: #8c7e6e;
    --text-dim: #6b5f50;
    --amber: #e8a23a;
    --amber-dim: rgba(232,162,58,0.12);
    --terracotta: #c4603a;
    --terracotta-dim: rgba(196,96,58,0.12);
    --sand: #d4c4a8;
    --olive: #7a8a5a;
    --olive-dim: rgba(122,138,90,0.12);
    --display: 'Newsreader', Georgia, 'Times New Roman', serif;
    --body: 'Outfit', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', monospace;
    --nav-bg: rgba(26,20,16,0.85);
    --card-shadow: rgba(0,0,0,0.2);
    --hero-glow: rgba(232,162,58,0.06);
    --grain-opacity: 0.03;
  }
  /* Light mode */
  @media (prefers-color-scheme: light) { :root:not([data-theme="dark"]) { --bg: #faf8f5; --surface: #fff; --surface2: #f5f0eb; --surface3: #ede6dd; --border: #d4c9ba; --border-subtle: #e8e0d5; --text: #2a2118; --text-secondary: #5a4d3e; --text-muted: #7a6d5e; --text-dim: #9a8d7e; --amber: #c48520; --amber-dim: rgba(196,133,32,0.1); --terracotta: #b0502a; --terracotta-dim: rgba(176,80,42,0.1); --nav-bg: rgba(250,248,245,0.88); --card-shadow: rgba(0,0,0,0.06); --hero-glow: rgba(232,162,58,0.08); --grain-opacity: 0.02; } }
  [data-theme="light"] { --bg: #faf8f5; --surface: #fff; --surface2: #f5f0eb; --surface3: #ede6dd; --border: #d4c9ba; --border-subtle: #e8e0d5; --text: #2a2118; --text-secondary: #5a4d3e; --text-muted: #7a6d5e; --text-dim: #9a8d7e; --amber: #c48520; --amber-dim: rgba(196,133,32,0.1); --terracotta: #b0502a; --terracotta-dim: rgba(176,80,42,0.1); --nav-bg: rgba(250,248,245,0.88); --card-shadow: rgba(0,0,0,0.06); --hero-glow: rgba(232,162,58,0.08); --grain-opacity: 0.02; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; overflow-x: hidden; }
  body { font-family: var(--body); background: var(--bg); color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

  /* GRAIN OVERLAY */
  body::after {
    content: ''; position: fixed; inset: 0; z-index: 9999; pointer-events: none; opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: var(--grain-opacity);
  }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 0 32px; height: 60px;
    display: flex; align-items: center; justify-content: space-between;
    background: var(--nav-bg); backdrop-filter: blur(16px) saturate(1.2);
    border-bottom: 1px solid var(--border-subtle);
  }
  .nav-left { display: flex; align-items: center; gap: 16px; }
  .nav-brand {
    font-family: var(--mono); font-weight: 600; font-size: 14px;
    color: var(--text); text-decoration: none; letter-spacing: -0.01em;
    display: flex; align-items: center; gap: 8px;
  }
  .nav-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--border); }
  .nav-tag {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-dim);
    padding: 3px 10px; border: 1px solid var(--border-subtle); border-radius: 4px;
  }
  .nav-right { display: flex; align-items: center; gap: 20px; }
  .nav-link {
    font-size: 13px; font-weight: 500; color: var(--text-muted);
    text-decoration: none; transition: color 0.2s;
  }
  .nav-link:hover { color: var(--text); }
  .nav-gh {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 6px; height: 30px;
    border: 1px solid var(--border); background: var(--surface);
    font-size: 13px; font-weight: 500; color: var(--text-muted);
    text-decoration: none; transition: all 0.2s;
  }
  .nav-gh:hover { border-color: var(--amber); color: var(--text); background: var(--surface2); }
  .nav-gh svg { width: 15px; height: 15px; }

  /* HERO */
  .hero {
    padding: 160px 32px 100px;
    max-width: 900px; margin: 0 auto;
    position: relative;
  }
  .hero::before {
    content: ''; position: absolute; top: 80px; right: -100px;
    width: 400px; height: 400px; border-radius: 50%;
    background: radial-gradient(circle, var(--hero-glow) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-logo {
    position: absolute; right: 32px; top: 50%; transform: translateY(-50%);
    width: 300px; height: 300px; opacity: 0.5; pointer-events: none;
  }
  .hero-eyebrow {
    font-family: var(--mono); font-size: 12px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--amber);
    margin-bottom: 24px; display: flex; align-items: center; gap: 12px;
  }
  .hero-eyebrow::before {
    content: ''; width: 32px; height: 1px; background: var(--amber); opacity: 0.5;
  }
  .hero h1 {
    font-family: var(--display); font-size: clamp(40px, 7vw, 64px);
    font-weight: 400; line-height: 1.1; letter-spacing: -0.02em;
    color: var(--text); margin-bottom: 24px;
  }
  .hero h1 em {
    font-style: italic; color: var(--amber);
    background: linear-gradient(135deg, var(--amber), var(--terracotta));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc {
    max-width: 520px; font-size: 17px; font-weight: 400;
    color: var(--text-secondary); line-height: 1.75;
  }
  /* LANG SWITCHER */
  .lang-switch {
    display: flex; gap: 0; border-radius: 6px; overflow: hidden;
    border: 1px solid var(--border);
  }
  .lang-btn {
    padding: 6px 12px; font-family: var(--mono); font-size: 11px;
    color: var(--text-dim); background: transparent; border: none;
    cursor: pointer; transition: all 0.2s; letter-spacing: 0.03em;
    text-decoration: none; display: inline-block;
  }
  .lang-btn:hover { color: var(--text-muted); }
  .lang-btn.active { background: var(--amber); color: #fff; font-weight: 600; }

  /* THEME TOGGLE */
  .theme-toggle {
    width: 30px; height: 30px; border-radius: 6px; border: 1px solid var(--border);
    background: transparent; color: var(--text-muted); cursor: pointer;
    display: flex; align-items: center; justify-content: center; transition: all 0.2s;
  }
  .theme-toggle:hover { color: var(--text); border-color: var(--amber); }
  .theme-toggle svg { width: 15px; height: 15px; }
  .theme-toggle .icon-sun { display: none; }
  .theme-toggle .icon-moon { display: block; }
  [data-theme="light"] .theme-toggle .icon-sun { display: block; }
  [data-theme="light"] .theme-toggle .icon-moon { display: none; }
  @media (prefers-color-scheme: light) {
    :root:not([data-theme="dark"]) .theme-toggle .icon-sun { display: block; }
    :root:not([data-theme="dark"]) .theme-toggle .icon-moon { display: none; }
  }

  /* DIVIDER */
  .section-divider {
    max-width: 900px; margin: 0 auto; padding: 0 32px;
    display: flex; align-items: center; gap: 16px;
  }
  .section-divider::before, .section-divider::after {
    content: ''; flex: 1; height: 1px; background: var(--border-subtle);
  }
  .section-divider span {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--text-dim); white-space: nowrap;
  }

  /* POSTS */
  .posts { max-width: 900px; margin: 0 auto; padding: 48px 32px 100px; }

  .post-card {
    display: grid; grid-template-columns: 1fr;
    padding: 32px; margin-bottom: 16px;
    background: var(--surface); border: 1px solid var(--border-subtle);
    border-radius: 16px; text-decoration: none; color: inherit;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative; overflow: hidden;
  }
  .post-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--amber), var(--terracotta));
    opacity: 0; transition: opacity 0.3s;
  }
  .post-card:hover {
    border-color: var(--border);
    background: var(--surface2);
    transform: translateY(-2px);
    box-shadow: 0 12px 40px var(--card-shadow);
  }
  .post-card:hover::before { opacity: 1; }
  .post-card:hover .post-arrow { opacity: 1; transform: translateX(0); }

  .post-header { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; }
  .post-version {
    font-family: var(--mono); font-size: 11px; font-weight: 600;
    color: var(--amber); background: var(--amber-dim);
    padding: 3px 10px; border-radius: 6px; letter-spacing: 0.02em;
  }
  .post-date {
    font-family: var(--mono); font-size: 12px; color: var(--text-dim);
  }
  .post-langs { display: flex; gap: 4px; margin-left: auto; }
  .post-lang {
    font-family: var(--mono); font-size: 10px; font-weight: 500;
    padding: 2px 7px; border-radius: 4px;
    background: var(--surface3); color: var(--text-dim);
  }

  .post-body { display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; }
  .post-content { flex: 1; }
  .post-title {
    font-family: var(--display); font-size: 26px; font-weight: 500;
    line-height: 1.25; margin-bottom: 10px; color: var(--text);
    letter-spacing: -0.01em; transition: color 0.2s;
  }
  .post-card:hover .post-title { color: var(--amber); }
  .post-excerpt {
    font-size: 14px; color: var(--text-muted); line-height: 1.7; max-width: 540px;
  }
  .post-tags { display: flex; gap: 6px; margin-top: 16px; flex-wrap: wrap; }
  .post-tag {
    font-family: var(--mono); font-size: 11px;
    padding: 4px 12px; border-radius: 6px;
    background: transparent; border: 1px solid var(--border-subtle);
    color: var(--text-dim); transition: all 0.2s;
  }
  .post-card:hover .post-tag { border-color: var(--border); }

  .post-arrow {
    width: 40px; height: 40px; border-radius: 10px;
    background: var(--amber-dim); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--amber); font-size: 18px; flex-shrink: 0;
    opacity: 0; transform: translateX(-8px);
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    margin-top: 4px;
  }

  /* FOOTER */
  .footer {
    border-top: 1px solid var(--border-subtle);
    padding: 48px 32px;
    max-width: 900px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-left { display: flex; flex-direction: column; gap: 6px; }
  .footer-brand {
    font-family: var(--mono); font-size: 13px; font-weight: 500; color: var(--text-muted);
  }
  .footer-brand a { color: var(--amber); text-decoration: none; }
  .footer-brand a:hover { text-decoration: underline; }
  .footer-note { font-size: 12px; color: var(--text-dim); }
  .footer-right { display: flex; align-items: center; gap: 20px; }
  .footer-link { font-size: 12px; color: var(--text-dim); text-decoration: none; transition: color 0.2s; }
  .footer-link:hover { color: var(--text-muted); }

  /* SEARCH */
  .search-wrap { position: relative; }
  .search-input {
    width: 140px; padding: 6px 10px 6px 30px; height: 30px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 6px; color: var(--text); font-family: var(--body);
    font-size: 12px; outline: none; transition: all 0.2s;
  }
  .search-input::placeholder { color: var(--text-dim); }
  .search-input:focus { border-color: var(--amber); width: 200px; }
  .search-icon {
    position: absolute; left: 8px; top: 50%; transform: translateY(-50%);
    color: var(--text-dim); pointer-events: none;
  }
  .no-results {
    text-align: center; padding: 40px 0; color: var(--text-dim);
    font-size: 14px; display: none;
  }

  /* PAGINATION */
  .pagination {
    display: flex; justify-content: center; align-items: center;
    gap: 8px; margin-top: 32px;
  }
  .page-btn {
    padding: 8px 14px; border-radius: 8px; border: 1px solid var(--border-subtle);
    background: transparent; color: var(--text-muted); font-family: var(--mono);
    font-size: 12px; cursor: pointer; transition: all 0.2s;
  }
  .page-btn:hover { border-color: var(--amber); color: var(--text); }
  .page-btn.active { background: var(--amber); color: #fff; border-color: var(--amber); }
  .page-btn:disabled { opacity: 0.3; cursor: default; }
  .page-btn:disabled:hover { border-color: var(--border-subtle); color: var(--text-muted); }
  .page-info { font-family: var(--mono); font-size: 11px; color: var(--text-dim); }

  /* RESPONSIVE */
  @media (max-width: 640px) {
    .nav { padding: 0 16px; height: 52px; }
    .nav-tag { display: none; }
    .nav-dot { display: none; }
    .nav-right { gap: 8px; }
    .search-input { width: 60px; font-size: 11px; padding-left: 24px; }
    .search-input:focus { width: 110px; }
    .search-icon svg { width: 11px; height: 11px; }
    .lang-btn { padding: 4px 7px; font-size: 10px; }
    .nav-gh > span { display: none; }
    .nav-gh { padding: 6px 8px; }
    .hero { padding: 100px 16px 48px; }
    .hero h1 { font-size: clamp(28px, 8vw, 36px); }
    .hero h1 br { display: none; }
    .hero-logo { position: static; transform: none; width: 64px; height: 64px; margin-bottom: 16px; opacity: 0.6; }
    .hero-desc { font-size: 15px; }
    .hero-eyebrow { font-size: 11px; margin-bottom: 16px; }
    .section-divider { padding: 0 16px; }
    .posts { padding: 32px 16px 60px; }
    .posts-label { margin-bottom: 16px; }
    .post-card { padding: 20px 16px; margin-bottom: 12px; border-radius: 12px; }
    .post-header { gap: 6px; margin-bottom: 12px; }
    .post-title { font-size: 19px; }
    .post-excerpt { font-size: 13px; }
    .post-langs { margin-left: 0; }
    .post-tags { gap: 4px; margin-top: 12px; }
    .post-tag { font-size: 10px; padding: 3px 8px; }
    .post-arrow { display: none; }
    .post-body { flex-direction: column; }
    .footer { flex-direction: column; gap: 16px; text-align: center; padding: 32px 16px; }
    .footer-right { justify-content: center; }
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-eyebrow { animation: fadeUp 0.6s ease both; }
  .hero h1 { animation: fadeUp 0.6s ease 0.08s both; }
  .hero-desc { animation: fadeUp 0.6s ease 0.16s both; }
  .post-card:nth-child(2) { animation: fadeUp 0.5s ease 0.24s both; }
  .post-card:nth-child(3) { animation: fadeUp 0.5s ease 0.34s both; }
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="nav-left">
    <a class="nav-brand" href="https://github.com/nextlevelbuilder/goclaw" target="_blank" rel="noopener">
      <img src="/goclaw-icon.svg" alt="" width="22" height="22" style="border-radius:4px;">
      GoClaw
    </a>
    <span class="nav-dot"></span>
    <span class="nav-tag">contributor notes</span>
  </div>
  <div class="nav-right">
    <div class="search-wrap">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input class="search-input" type="text" placeholder={t.search}>
    </div>
    <div class="lang-switch">
      {(['vi', 'en', 'zh', 'ja'] as const).map(lang => (
        <a
          class:list={['lang-btn', { active: lang === locale }]}
          href={lang === 'vi' ? '/' : `/${lang}`}
        >
          {lang === 'zh' ? 'CN' : lang === 'ja' ? 'JP' : lang.toUpperCase()}
        </a>
      ))}
    </div>
    <button class="theme-toggle" aria-label="Toggle theme">
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
    </button>
    <a class="nav-gh" href="https://github.com/nextlevelbuilder/goclaw" target="_blank" rel="noopener">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      <span>Source</span>
    </a>
  </div>
</nav>

<!-- HERO -->
<header class="hero">
  <img src="/goclaw-icon.svg" alt="" class="hero-logo">
  <div class="hero-eyebrow">Inside GoClaw</div>
  <h1><Fragment set:html={t.heroTitle} /></h1>
  <p class="hero-desc">{t.heroDesc}</p>
</header>

<!-- DIVIDER -->
<div class="section-divider"><span>{t.divider}</span></div>

<!-- POSTS -->
<main class="posts">
  <div class="no-results">{t.noResults}</div>
  <div class="posts-list">
    {posts.map(post => (
      <a class="post-card" href={postUrl(post.slug)}>
        <div class="post-header">
          <span class="post-version">{post.version}</span>
          <span class="post-date">{post.date}</span>
        </div>
        <div class="post-body">
          <div class="post-content">
            <div class="post-title">{post.title[locale]}</div>
            <p class="post-excerpt">{post.excerpt[locale]}</p>
            <div class="post-tags">
              {post.tags.map(tag => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
          </div>
          <div class="post-arrow"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></div>
        </div>
      </a>
    ))}
  </div>
  <div class="pagination"></div>
</main>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-left">
    <div class="footer-brand"><a href="https://github.com/nextlevelbuilder/goclaw">GoClaw</a> — Multi-Tenant AI Agent Platform</div>
    <div class="footer-note">{t.footerNote}</div>
  </div>
  <div class="footer-right">
    <a class="footer-link" href="https://github.com/nextlevelbuilder/goclaw">GitHub</a>
    <a class="footer-link" href="https://goclaw.thieunv.space">goclaw.thieunv.space</a>
  </div>
</footer>

<script>
// Search & Pagination
const POSTS_PER_PAGE = 5;
let currentPage = 1;
const searchInput = document.querySelector('.search-input') as HTMLInputElement;
const postsList = document.querySelector('.posts-list') as HTMLElement;
const allCards = Array.from(postsList.querySelectorAll('.post-card')) as HTMLElement[];
const noResults = document.querySelector('.no-results') as HTMLElement;
const paginationEl = document.querySelector('.pagination') as HTMLElement;

function getVisibleCards(): HTMLElement[] {
  const q = searchInput.value.toLowerCase().trim();
  return allCards.filter(card => {
    if (!q) return true;
    const text = card.textContent?.toLowerCase() ?? '';
    return text.includes(q);
  });
}

function renderPage(): void {
  const visible = getVisibleCards();
  const totalPages = Math.max(1, Math.ceil(visible.length / POSTS_PER_PAGE));
  if (currentPage > totalPages) currentPage = totalPages;
  const start = (currentPage - 1) * POSTS_PER_PAGE;
  const end = start + POSTS_PER_PAGE;

  allCards.forEach(c => c.style.display = 'none');
  visible.forEach((c, i) => c.style.display = (i >= start && i < end) ? '' : 'none');
  noResults.style.display = visible.length === 0 ? 'block' : 'none';

  // Pagination buttons
  if (totalPages <= 1) { paginationEl.innerHTML = ''; return; }
  let html = `<button class="page-btn" data-page="prev" ${currentPage === 1 ? 'disabled' : ''}>&larr;</button>`;
  for (let i = 1; i <= totalPages; i++) {
    html += `<button class="page-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
  }
  html += `<button class="page-btn" data-page="next" ${currentPage === totalPages ? 'disabled' : ''}>&rarr;</button>`;
  paginationEl.innerHTML = html;
  paginationEl.querySelectorAll('.page-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = (btn as HTMLButtonElement).dataset.page;
      if (p === 'prev') currentPage--;
      else if (p === 'next') currentPage++;
      else currentPage = parseInt(p!);
      renderPage();
    });
  });
}

searchInput.addEventListener('input', () => { currentPage = 1; renderPage(); });
renderPage();

// Theme toggle
const themeToggle = document.querySelector('.theme-toggle') as HTMLButtonElement;
const savedTheme = localStorage.getItem('goclaw-blog-theme');
if (savedTheme) document.documentElement.setAttribute('data-theme', savedTheme);

themeToggle.addEventListener('click', () => {
  const current = document.documentElement.getAttribute('data-theme');
  const isCurrentlyLight = current === 'light' || (!current && window.matchMedia('(prefers-color-scheme: light)').matches);
  const next = isCurrentlyLight ? 'dark' : 'light';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('goclaw-blog-theme', next);
});
</script>
</body>
</html>
