<!-- ════ MERMAID ════ -->
<script type="module">
import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

const isDark = document.documentElement.getAttribute('data-theme') !== 'light';

mermaid.initialize({
  startOnLoad: false,
  theme: 'base',
  look: 'classic',
  themeVariables: {
    primaryColor:        isDark ? '#111827' : '#f0ede8',
    primaryBorderColor:  isDark ? '#e8a020' : '#c27a08',
    primaryTextColor:    isDark ? '#e8f0f8' : '#1a1208',
    secondaryColor:      isDark ? '#161f30' : '#e8e4de',
    secondaryBorderColor:isDark ? '#06b6d4' : '#0891b2',
    secondaryTextColor:  isDark ? '#e8f0f8' : '#1a1208',
    tertiaryColor:       isDark ? '#1a1508' : '#fef9e8',
    tertiaryBorderColor: isDark ? '#e8a020' : '#b45309',
    tertiaryTextColor:   isDark ? '#e8a020' : '#3d2a08',
    lineColor:           isDark ? '#2a3a4a' : '#a09080',
    fontSize:            '14px',
    fontFamily:          "'Space Grotesk', system-ui, sans-serif",
    noteBkgColor:        isDark ? '#161f30' : '#fef9e8',
    noteTextColor:       isDark ? '#e8f0f8' : '#1a1208',
    noteBorderColor:     isDark ? '#e8a020' : '#b45309',
  }
});

const config = { minZoom: 0.3, maxZoom: 3, zoomStep: 0.15, fitPadding: 20 };
const clamp = (n, lo, hi) => Math.max(lo, Math.min(hi, n));
let activeDrag = null;
addEventListener('mousemove', e => activeDrag?.onMove(e));
addEventListener('mouseup', () => { activeDrag?.onEnd(); activeDrag = null; });

async function initDiagram(shell) {
  const wrap     = shell.querySelector('.mermaid-wrap');
  const viewport = shell.querySelector('.mermaid-viewport');
  const canvas   = shell.querySelector('.mermaid-canvas');
  const source   = shell.querySelector('.diagram-source');
  const label    = shell.querySelector('.zoom-label');
  if (!wrap || !viewport || !canvas || !source || !label) return;

  let zoom = 1, panX = 0, panY = 0;

  function update() {
    canvas.style.transform = \`translate(\${panX}px, \${panY}px)\`;
    canvas.style.width  = (canvas._baseW * zoom) + 'px';
    canvas.style.height = (canvas._baseH * zoom) + 'px';
    label.textContent = Math.round(zoom * 100) + '%';
  }

  function fit() {
    if (!canvas._baseW) return;
    const vw = viewport.clientWidth, vh = viewport.clientHeight;
    const p = config.fitPadding;
    zoom = clamp(Math.min((vw - p*2) / canvas._baseW, (vh - p*2) / canvas._baseH), config.minZoom, config.maxZoom);
    panX = (vw - canvas._baseW * zoom) / 2;
    panY = (vh - canvas._baseH * zoom) / 2;
    update();
  }

  try {
    const code = source.textContent.trim();
    if (!code) { label.textContent = 'Empty'; return; }
    const id = 'dia-' + Date.now() + '-' + Math.random().toString(36).slice(2,6);
    const { svg } = await mermaid.render(id, code);
    canvas.innerHTML = svg;
    const svgEl = canvas.querySelector('svg');
    if (svgEl) {
      canvas._baseW = svgEl.viewBox?.baseVal?.width  || svgEl.clientWidth  || 600;
      canvas._baseH = svgEl.viewBox?.baseVal?.height || svgEl.clientHeight || 400;
      svgEl.style.width  = '100%';
      svgEl.style.height = '100%';
      svgEl.removeAttribute('width');
      svgEl.removeAttribute('height');
    }
    fit();
  } catch(err) {
    console.error('Mermaid render failed:', err);
    label.textContent = 'Error';
    canvas.innerHTML = '<p style="color:var(--red);padding:20px;">Render failed: ' + (err.message||'') + '</p>';
    return;
  }

  wrap.querySelectorAll('.zoom-controls button').forEach(btn => {
    btn.addEventListener('click', () => {
      const a = btn.dataset.action;
      if (a === 'zoom-in')  { zoom = clamp(zoom + config.zoomStep, config.minZoom, config.maxZoom); }
      else if (a === 'zoom-out') { zoom = clamp(zoom - config.zoomStep, config.minZoom, config.maxZoom); }
      else if (a === 'zoom-fit') { fit(); return; }
      else if (a === 'zoom-one') { zoom = 1; panX = (viewport.clientWidth - canvas._baseW) / 2; panY = 0; }
      else if (a === 'zoom-expand') {
        const w = window.open('', '_blank');
        w.document.write('<html><body style="margin:0;display:flex;justify-content:center;background:#06090f;">' + canvas.innerHTML + '</body></html>');
        return;
      }
      update();
    });
  });

  viewport.addEventListener('wheel', e => {
    if (!e.ctrlKey && !e.metaKey) return;
    e.preventDefault();
    const oldZ = zoom;
    zoom = clamp(zoom + (e.deltaY < 0 ? config.zoomStep : -config.zoomStep), config.minZoom, config.maxZoom);
    const rect = viewport.getBoundingClientRect();
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    panX = mx - (mx - panX) * (zoom / oldZ);
    panY = my - (my - panY) * (zoom / oldZ);
    update();
  }, { passive: false });

  viewport.addEventListener('mousedown', e => {
    if (e.button !== 0) return;
    const sx = e.clientX - panX, sy = e.clientY - panY;
    wrap.classList.add('is-panning');
    activeDrag = {
      onMove: me => { panX = me.clientX - sx; panY = me.clientY - sy; update(); },
      onEnd:  ()  => { wrap.classList.remove('is-panning'); }
    };
  });

  viewport.addEventListener('dblclick', () => fit());
}

document.querySelectorAll('.diagram-shell').forEach(initDiagram);
</script>

<!-- ════ SCROLL SPY ════ -->
<script>
(function(){
  const toc = document.getElementById('toc');
  const links = toc.querySelectorAll('.toc-link');
  const sections = [];
  links.forEach(link => {
    const id = link.getAttribute('href').slice(1);
    const el = document.getElementById(id);
    if (el) sections.push({ id, el, link });
  });

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        links.forEach(l => l.classList.remove('active'));
        const match = sections.find(s => s.el === entry.target);
        if (match) {
          match.link.classList.add('active');
          if (window.innerWidth <= 1000) {
            match.link.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
          }
        }
      }
    });
  }, { rootMargin: '-10% 0px -80% 0px' });

  sections.forEach(s => observer.observe(s.el));

  links.forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const id = link.getAttribute('href').slice(1);
      const el = document.getElementById(id);
      if (el) { el.scrollIntoView({ behavior: 'smooth', block: 'start' }); history.replaceState(null, '', '#' + id); }
    });
  });
})();
</script>

