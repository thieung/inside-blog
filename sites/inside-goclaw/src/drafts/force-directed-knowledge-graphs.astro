---
// Draft: force-directed-knowledge-graphs — raw HTML preserved
const rawHtml = `<!DOCTYPE html>
<html lang="vi" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GoClaw v2.47.0 — Force-Directed Knowledge Graph Visualization</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
/* ─── Design Tokens ─── */
:root {
  --font-body: 'Space Grotesk', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;

  /* Dark theme (default) */
  --bg:             #080c12;
  --bg-grid:        rgba(255,255,255,0.025);
  --surface:        #0d1320;
  --surface2:       #111827;
  --surface3:       #161f30;
  --border:         rgba(255,255,255,0.07);
  --border-hi:      rgba(255,255,255,0.13);
  --text:           #b8c8d8;
  --text-dim:       #4a5f78;
  --text-bright:    #e8f0f8;
  --text-hi:        #ffffff;

  /* Brand accent — amber-gold, not a typical AI blue */
  --accent:         #e8a020;
  --accent-dim:     rgba(232,160,32,0.08);
  --accent-hi:      #f5b840;

  /* Semantic colors */
  --green:          #22c55e;
  --green-dim:      rgba(34,197,94,0.08);
  --red:            #ef4444;
  --red-dim:        rgba(239,68,68,0.08);
  --teal:           #06b6d4;
  --teal-dim:       rgba(6,182,212,0.08);
  --violet:         #a78bfa;
  --violet-dim:     rgba(167,139,250,0.08);

  /* Entity type palette */
  --clr-person:     #f97316;
  --clr-project:    #3b82f6;
  --clr-task:       #10b981;
  --clr-event:      #a78bfa;
  --clr-concept:    #e8a020;
  --clr-location:   #ef4444;
  --clr-org:        #06b6d4;

  --radius-sm:  6px;
  --radius-md:  10px;
  --radius-lg:  14px;
}

[data-theme="light"] {
  --bg:             #f5f3ef;
  --bg-grid:        rgba(0,0,0,0.04);
  --surface:        #ffffff;
  --surface2:       #f0ede8;
  --surface3:       #e8e4de;
  --border:         rgba(0,0,0,0.08);
  --border-hi:      rgba(0,0,0,0.15);
  --text:           #3d3228;
  --text-dim:       #8a7a6a;
  --text-bright:    #1a1208;
  --text-hi:        #000000;
  --accent:         #c27a08;
  --accent-dim:     rgba(194,122,8,0.08);
  --accent-hi:      #a06005;
  --green:          #15803d;
  --green-dim:      rgba(21,128,61,0.08);
  --red:            #dc2626;
  --red-dim:        rgba(220,38,38,0.08);
  --teal:           #0891b2;
  --teal-dim:       rgba(8,145,178,0.08);
  --violet:         #7c3aed;
  --violet-dim:     rgba(124,58,237,0.08);
  --clr-person:     #c2410c;
  --clr-project:    #1d4ed8;
  --clr-task:       #047857;
  --clr-event:      #6d28d9;
  --clr-concept:    #b45309;
  --clr-location:   #b91c1c;
  --clr-org:        #0e7490;
}

/* ─── Reset & Base ─── */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  background-image:
    linear-gradient(var(--bg-grid) 1px, transparent 1px),
    linear-gradient(90deg, var(--bg-grid) 1px, transparent 1px);
  background-size: 40px 40px;
  color: var(--text);
  line-height: 1.7;
  min-height: 100dvh;
}

/* ─── Layout ─── */
.page {
  display: grid;
  grid-template-columns: 200px 1fr;
  grid-template-rows: auto 1fr;
  max-width: 1320px;
  margin: 0 auto;
  padding: 0 32px 80px;
  gap: 0 48px;
}

.header-area {
  grid-column: 1 / -1;
  padding: 56px 0 48px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 48px;
  position: relative;
}

.main-content { min-width: 0; }

/* ─── Fixed Nav Buttons ─── */
.fixed-nav {
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 500;
  display: flex;
  gap: 8px;
}

.nav-btn {
  width: 38px;
  height: 38px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border-hi);
  background: var(--surface2);
  color: var(--text-dim);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  transition: background .15s, color .15s, border-color .15s;
  text-decoration: none;
  font-family: var(--font-body);
}

.nav-btn:hover {
  background: var(--surface3);
  color: var(--text-bright);
  border-color: var(--border-hi);
}

/* ─── Header ─── */
.post-eyebrow {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.post-eyebrow::before {
  content: '';
  width: 24px;
  height: 1px;
  background: var(--accent);
  flex-shrink: 0;
}

.post-title {
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 700;
  color: var(--text-hi);
  letter-spacing: -0.03em;
  line-height: 1.08;
  max-width: 820px;
  margin-bottom: 24px;
}

.post-title em {
  color: var(--accent);
  font-style: normal;
}

.post-deck {
  font-size: 1.15rem;
  color: var(--text-dim);
  max-width: 640px;
  line-height: 1.6;
  font-weight: 400;
  margin-bottom: 32px;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}

.meta-tag {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 1px;
  padding: 4px 12px;
  border-radius: 100px;
  border: 1px solid var(--border-hi);
  color: var(--text-dim);
  background: var(--surface);
}

.meta-tag--accent {
  border-color: var(--accent);
  color: var(--accent);
  background: var(--accent-dim);
}

/* ─── TOC ─── */
.toc-sidebar {
  position: sticky;
  top: 24px;
  align-self: start;
  max-height: calc(100dvh - 48px);
  overflow-y: auto;
  padding-right: 16px;
}

.toc-sidebar::-webkit-scrollbar { width: 2px; }
.toc-sidebar::-webkit-scrollbar-thumb { background: var(--surface3); border-radius: 2px; }

.toc-label {
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--text-dim);
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 12px;
}

.toc-link {
  display: block;
  font-size: 12px;
  color: var(--text-dim);
  text-decoration: none;
  padding: 5px 10px 5px 12px;
  border-left: 2px solid transparent;
  border-radius: 0 4px 4px 0;
  transition: all .15s;
  line-height: 1.4;
  margin-bottom: 2px;
  font-weight: 400;
}

.toc-link:hover { color: var(--text); background: var(--surface2); }
.toc-link.active {
  color: var(--accent-hi);
  border-left-color: var(--accent);
  background: var(--accent-dim);
  font-weight: 500;
}

/* ─── Section Heads ─── */
.sec-label {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--accent);
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 64px 0 4px;
  scroll-margin-top: 24px;
}

.sec-label::before {
  content: '';
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
}

h2.sec-title {
  font-size: 1.7rem;
  font-weight: 700;
  color: var(--text-bright);
  letter-spacing: -0.025em;
  margin-bottom: 20px;
  line-height: 1.2;
}

h3 {
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--text-bright);
  margin: 32px 0 10px;
  letter-spacing: -0.01em;
}

p { margin-bottom: 16px; font-size: 15px; }

/* ─── KPI Strip ─── */
.kpi-strip {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin: 28px 0 36px;
}

.kpi-item {
  background: var(--surface);
  padding: 20px 16px;
  text-align: center;
}

.kpi-value {
  font-family: var(--font-mono);
  font-size: 2rem;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
  margin-bottom: 6px;
}

.kpi-label {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--text-dim);
}

/* ─── Cards ─── */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 20px 24px;
  margin-bottom: 16px;
}

.card--hero {
  background: var(--surface2);
  border-color: var(--border-hi);
}

.card--accent-left {
  border-left: 3px solid var(--accent);
}

.card--warning {
  border-left: 3px solid var(--accent);
  background: color-mix(in srgb, var(--surface) 95%, var(--accent) 5%);
}

.card--green { border-left: 3px solid var(--green); }
.card--teal  { border-left: 3px solid var(--teal); }

.card-label {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.card-label::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}

/* ─── Code ─── */
code {
  font-family: var(--font-mono);
  font-size: 0.85em;
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  color: var(--accent-hi);
  padding: 2px 6px;
  border-radius: 4px;
}

.code-file {
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin: 14px 0 24px;
}

.code-file__header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  background: var(--surface2);
  border-bottom: 1px solid var(--border);
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-dim);
}

.code-file__header::before {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent-dim);
  border: 1px solid var(--accent);
  flex-shrink: 0;
}

.code-file__body {
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 1.65;
  padding: 18px;
  background: var(--surface);
  white-space: pre-wrap;
  word-break: break-word;
  max-height: 500px;
  overflow: auto;
  color: var(--text);
}

.code-block {
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 1.65;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 16px;
  overflow-x: auto;
  white-space: pre-wrap;
  word-break: break-word;
  margin: 10px 0 20px;
}

/* ─── Tables ─── */
.table-wrap { overflow-x: auto; margin: 12px 0 24px; }

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}

.data-table th {
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--text-dim);
  text-align: left;
  padding: 10px 14px;
  border-bottom: 1px solid var(--border-hi);
  background: var(--surface2);
}

.data-table th:first-child { border-radius: var(--radius-sm) 0 0 0; }
.data-table th:last-child { border-radius: 0 var(--radius-sm) 0 0; }

.data-table td {
  padding: 10px 14px;
  border-bottom: 1px solid var(--border);
  vertical-align: top;
}

.data-table tr:last-child td { border-bottom: none; }

.data-table tr:hover td { background: var(--surface2); }

/* ─── Entity Badges ─── */
.eb {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 500;
  padding: 3px 9px;
  border-radius: 100px;
  border: 1px solid;
}
.eb::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
.eb-person   { color:var(--clr-person);  border-color:var(--clr-person);  background:rgba(249,115,22,0.08); }
.eb-project  { color:var(--clr-project); border-color:var(--clr-project); background:rgba(59,130,246,0.08); }
.eb-task     { color:var(--clr-task);    border-color:var(--clr-task);    background:rgba(16,185,129,0.08); }
.eb-event    { color:var(--clr-event);   border-color:var(--clr-event);   background:rgba(167,139,250,0.08); }
.eb-concept  { color:var(--clr-concept); border-color:var(--clr-concept); background:rgba(232,160,32,0.08); }
.eb-location { color:var(--clr-location);border-color:var(--clr-location);background:rgba(239,68,68,0.08); }
.eb-org      { color:var(--clr-org);     border-color:var(--clr-org);     background:rgba(6,182,212,0.08); }

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 12px 0 24px;
}

/* ─── Pipeline ─── */
.pipeline {
  display: flex;
  gap: 0;
  align-items: stretch;
  margin: 20px 0 28px;
  flex-wrap: wrap;
}

.pipeline-step {
  flex: 1;
  min-width: 100px;
  padding: 14px 12px;
  background: var(--surface);
  border: 1px solid var(--border);
  position: relative;
  text-align: center;
}

.pipeline-step:first-child { border-radius: var(--radius-sm) 0 0 var(--radius-sm); }
.pipeline-step:last-child  { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }
.pipeline-step:not(:first-child) { border-left: none; }

.pipeline-step:not(:last-child)::after {
  content: '';
  position: absolute;
  right: -9px;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border: 9px solid transparent;
  border-left-color: var(--border-hi);
  z-index: 2;
}

.pipeline-step:not(:last-child)::before {
  content: '';
  position: absolute;
  right: -8px;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border: 8px solid transparent;
  border-left-color: var(--surface);
  z-index: 3;
}

.ps-num {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--accent);
  display: block;
  margin-bottom: 4px;
  letter-spacing: 1px;
}

.ps-label { font-size: 12px; font-weight: 600; color: var(--text-bright); }

/* ─── Depth Viz ─── */
.depth-viz { display: flex; flex-direction: column; gap: 0; margin: 24px 0; }

.depth-level {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  position: relative;
  padding: 16px 0 16px 64px;
}

.depth-level::before {
  content: attr(data-depth);
  position: absolute;
  left: 0;
  top: 16px;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 13px;
  font-weight: 700;
  border: 1px solid var(--accent);
  color: var(--accent);
  background: var(--bg);
}

.depth-level:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 19px;
  top: 56px;
  bottom: 0;
  width: 1px;
  background: var(--border-hi);
}

.depth-nodes { display: flex; flex-wrap: wrap; gap: 10px; }

.depth-node {
  padding: 8px 14px;
  border-radius: var(--radius-sm);
  border: 1px solid;
  font-size: 13px;
  font-weight: 500;
}

.depth-node small {
  display: block;
  font-family: var(--font-mono);
  font-size: 10px;
  opacity: .6;
  margin-top: 3px;
}

/* ─── Mermaid Diagrams ─── */
.diagram-shell { position: relative; margin: 20px 0 28px; }

.diagram-hint {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text-dim);
  margin-bottom: 8px;
  opacity: .7;
}

.mermaid-wrap {
  position: relative;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 32px 24px;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 400px;
  cursor: grab;
}

.mermaid-wrap--compact { min-height: 200px; }
.mermaid-wrap.is-panning { cursor: grabbing; user-select: none; }

.zoom-controls {
  position: absolute;
  top: 10px;
  right: 10px;
  display: flex;
  gap: 2px;
  z-index: 10;
  background: var(--surface2);
  border: 1px solid var(--border-hi);
  border-radius: var(--radius-sm);
  padding: 3px;
}

.zoom-controls button {
  width: 26px;
  height: 26px;
  border: none;
  background: transparent;
  color: var(--text-dim);
  font-family: var(--font-mono);
  font-size: 13px;
  cursor: pointer;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .1s, color .1s;
}

.zoom-controls button:hover { background: var(--border); color: var(--text-bright); }

.zoom-label {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text-dim);
  padding: 0 6px;
  white-space: nowrap;
  display: flex;
  align-items: center;
}

.mermaid-viewport {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 100%;
  min-height: 300px;
}

.mermaid-canvas { position: absolute; top: 0; left: 0; }

/* ─── Perf Grid ─── */
.perf-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin: 14px 0 24px;
}

.perf-col {
  padding: 16px;
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
}

.perf-col--before {
  background: var(--red-dim);
  border-color: color-mix(in srgb, var(--red) 25%, transparent);
}

.perf-col--after {
  background: var(--green-dim);
  border-color: color-mix(in srgb, var(--green) 25%, transparent);
}

.perf-col__title {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 10px;
  font-weight: 600;
}

.perf-col--before .perf-col__title { color: var(--red); }
.perf-col--after .perf-col__title  { color: var(--green); }

/* ─── Callout ─── */
.callout {
  border-left: 3px solid var(--accent);
  padding: 14px 18px;
  background: var(--accent-dim);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  margin: 16px 0 24px;
  font-size: 14px;
}

.callout strong { color: var(--accent-hi); }

/* ─── Lists ─── */
ul, ol { padding-left: 22px; margin-bottom: 16px; }
li { margin-bottom: 7px; font-size: 15px; }

/* ─── Divider ─── */
.sec-divider {
  height: 1px;
  background: var(--border);
  margin: 8px 0 0;
}

/* ─── Responsive ─── */
@media (max-width: 1000px) {
  .page {
    grid-template-columns: 1fr;
    padding: 0 20px 60px;
    gap: 0;
  }

  .header-area { padding: 40px 0 32px; }

  .toc-sidebar {
    position: sticky;
    top: 0;
    z-index: 200;
    max-height: none;
    display: flex;
    gap: 4px;
    align-items: center;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 10px 0;
    margin: 0 -20px;
    padding-left: 20px;
    padding-right: 20px;
    grid-row: auto;
  }

  .toc-sidebar::-webkit-scrollbar { display: none; }
  .toc-label { display: none; }

  .toc-link {
    white-space: nowrap;
    flex-shrink: 0;
    border-left: none;
    border-bottom: 2px solid transparent;
    border-radius: 4px 4px 0 0;
    padding: 5px 10px;
    font-size: 10px;
  }

  .toc-link.active {
