scene.add(new THREE.Points(starGeo,new THREE.PointsMaterial({color:0x334455,size:0.06,transparent:true,opacity:0.5})));

const nodeMeshes=[];
const nodeGroup=new THREE.Group();
entities.forEach(e=>{
  const geo=new THREE.SphereGeometry(e.id==='e1'?0.52:0.36,24,24);
  const mat=new THREE.MeshStandardMaterial({color:TCH[e.type],emissive:TCH[e.type],emissiveIntensity:0.15,roughness:0.3,metalness:0.1});
  const mesh=new THREE.Mesh(geo,mat);
  mesh.position.set(...e.p);
  mesh.userData={entity:e,baseEmissive:0.15};
  nodeGroup.add(mesh);
  nodeMeshes.push(mesh);
  const div=document.createElement('div');
  div.style.cssText=\`font:600 11px 'Space Grotesk',system-ui;color:\${TCHS[e.type]};text-shadow:0 0 8px rgba(0,0,0,0.9);pointer-events:none;white-space:nowrap;\`;
  div.textContent=e.name;
  const lbl=new CSS2DObject(div);
  lbl.position.set(0,e.id==='e1'?0.72:0.56,0);
  mesh.add(lbl);
});
scene.add(nodeGroup);

const edgeGroup=new THREE.Group();
const edgeMeshes=[];
rels.forEach(r=>{
  const s=nMap.get(r.s),t=nMap.get(r.t);
  if(!s||!t) return;
  const sp=new THREE.Vector3(...s.p),tp=new THREE.Vector3(...t.p);
  const mid=sp.clone().add(tp).multiplyScalar(0.5);
  const dir=tp.clone().sub(sp).normalize();
  const perp=new THREE.Vector3(-dir.y,dir.x,dir.z*0.3).normalize().multiplyScalar(0.6);
  mid.add(perp);
  const curve=new THREE.QuadraticBezierCurve3(sp,mid,tp);
  const pts=curve.getPoints(32);
  const geo=new THREE.BufferGeometry().setFromPoints(pts);
  const mat=new THREE.LineBasicMaterial({color:0x1a2a3a,transparent:true,opacity:0.2});
  const line=new THREE.Line(geo,mat);
  line.userData={rel:r,curve};
  edgeGroup.add(line);
  edgeMeshes.push(line);
});
scene.add(edgeGroup);

const PARTICLE_COUNT=120;
const pGeo=new THREE.BufferGeometry();
const pPos=new Float32Array(PARTICLE_COUNT*3);
const pCol=new Float32Array(PARTICLE_COUNT*3);
pGeo.setAttribute('position',new THREE.BufferAttribute(pPos,3));
pGeo.setAttribute('color',new THREE.BufferAttribute(pCol,3));
const pMat=new THREE.PointsMaterial({size:0.07,vertexColors:true,transparent:true,opacity:0.9,blending:THREE.AdditiveBlending});
const particles=new THREE.Points(pGeo,pMat);
particles.visible=false;
scene.add(particles);

scene.add(new THREE.AmbientLight(0x1a2233,0.7));
const dLight=new THREE.DirectionalLight(0xffffff,0.7);
dLight.position.set(5,8,5);scene.add(dLight);
const pLight=new THREE.PointLight(0xe8a020,0.3,20);
pLight.position.set(0,5,0);scene.add(pLight);

const raycaster=new THREE.Raycaster();
const mouse=new THREE.Vector2();
let selected=null;

function select(entity){
  selected=entity;
  nodeMeshes.forEach(m=>{m.material.emissiveIntensity=0.15;m.scale.setScalar(1);m.children[0].element.style.opacity='1';});
  edgeMeshes.forEach(l=>{l.material.opacity=0.2;l.material.color.set(0x1a2a3a);});
  particles.visible=false;
  bloom.strength=0.5;
  if(!entity) return;
  bloom.strength=1.0;
  const connIds=new Set([entity.id]);
  const connCurves=[];
  rels.forEach((r,i)=>{
    if(r.s===entity.id||r.t===entity.id){
      connIds.add(r.s);connIds.add(r.t);
      edgeMeshes[i].material.color.set(TCH[entity.type]);
      edgeMeshes[i].material.opacity=0.85;
      connCurves.push(edgeMeshes[i].userData.curve);
    }
  });
  nodeMeshes.forEach(m=>{
    if(!connIds.has(m.userData.entity.id)){m.material.emissiveIntensity=0.02;m.children[0].element.style.opacity='0.12';}
    else if(m.userData.entity.id===entity.id){m.material.emissiveIntensity=0.6;m.scale.setScalar(1.3);}
    else m.material.emissiveIntensity=0.3;
  });
  particles.visible=true;
  const clr=new THREE.Color(TCH[entity.type]);
  for(let i=0;i<PARTICLE_COUNT;i++){
    const ci=i%connCurves.length;
    const pt=connCurves[ci].getPoint(Math.random());
    pPos[i*3]=pt.x;pPos[i*3+1]=pt.y;pPos[i*3+2]=pt.z;
    pCol[i*3]=clr.r;pCol[i*3+1]=clr.g;pCol[i*3+2]=clr.b;
  }
  pGeo.attributes.position.needsUpdate=true;
  pGeo.attributes.color.needsUpdate=true;
}

let clickT=0;
renderer.domElement.addEventListener('pointerdown',()=>{clickT=Date.now();});
renderer.domElement.addEventListener('pointerup',e=>{
  if(Date.now()-clickT>300) return;
  const rect=renderer.domElement.getBoundingClientRect();
  mouse.x=((e.clientX-rect.left)/rect.width)*2-1;
  mouse.y=-((e.clientY-rect.top)/rect.height)*2+1;
  raycaster.setFromCamera(mouse,camera);
  const hits=raycaster.intersectObjects(nodeMeshes);
  if(hits.length>0){const ent=hits[0].object.userData.entity;select(selected&&selected.id===ent.id?null:ent);}
  else select(null);
});
renderer.domElement.addEventListener('dblclick',e=>{
  const rect=renderer.domElement.getBoundingClientRect();
  mouse.x=((e.clientX-rect.left)/rect.width)*2-1;
  mouse.y=-((e.clientY-rect.top)/rect.height)*2+1;
  raycaster.setFromCamera(mouse,camera);
  const hits=raycaster.intersectObjects(nodeMeshes);
  if(hits.length>0) showDetail(hits[0].object.userData.entity);
});

const clock=new THREE.Clock();
function animate(){
  requestAnimationFrame(animate);
  const t=clock.getElapsedTime();
  ctrl.update();
  nodeMeshes.forEach((m,i)=>{const e=m.userData.entity;m.position.x=e.p[0]+Math.sin(t*0.3+i)*0.08;m.position.y=e.p[1]+Math.cos(t*0.4+i*1.3)*0.08;m.position.z=e.p[2]+Math.sin(t*0.35+i*0.7)*0.06;});
  if(particles.visible&&selected){
    const cc=[];rels.forEach((r,i)=>{if(r.s===selected.id||r.t===selected.id) cc.push(edgeMeshes[i].userData.curve);});
    if(cc.length) for(let i=0;i<PARTICLE_COUNT;i++){const ci=i%cc.length;const tt=((t*(0.15+((i*7)%13)/13*0.25)+i*0.037)%1+1)%1;const pt=cc[ci].getPoint(tt);pPos[i*3]=pt.x;pPos[i*3+1]=pt.y;pPos[i*3+2]=pt.z;}
    pGeo.attributes.position.needsUpdate=true;
  }
  if(selected){const sm=nodeMeshes.find(m=>m.userData.entity.id===selected.id);if(sm) sm.material.emissiveIntensity=0.4+Math.sin(t*3)*0.2;}
  composer.render();
  labelRenderer.render(scene,camera);
}
animate();

new ResizeObserver(()=>{const w=ctr.clientWidth,h=ctr.clientHeight;camera.aspect=w/h;camera.updateProjectionMatrix();renderer.setSize(w,h);labelRenderer.setSize(w,h);composer.setSize(w,h);}).observe(ctr);

function showDetail(n){
  if(!n) return;
  const myRels=rels.filter(r=>r.s===n.id||r.t===n.id);
  let rows=myRels.map(r=>{const dir=r.s===n.id?'outgoing':'incoming';const o=r.s===n.id?nMap.get(r.t):nMap.get(r.s);return \`<tr><td style="padding:8px 12px;border-bottom:1px solid var(--border);font-size:13px;">\${dir==='outgoing'?'→ outgoing':'← incoming'}</td><td style="padding:8px 12px;border-bottom:1px solid var(--border);font-family:var(--font-mono);font-size:12px;color:\${TCHS[n.type]};">\${r.tp}</td><td style="padding:8px 12px;border-bottom:1px solid var(--border);font-size:13px;">\${o?o.name:'?'}</td><td style="padding:8px 12px;border-bottom:1px solid var(--border);font-family:var(--font-mono);font-size:12px;">\${Math.round((o?.confidence||.8)*100)}%</td></tr>\`;}).join('');
  document.getElementById('kg-dialog-content').innerHTML=\`<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;"><h3 style="font-size:1.3rem;margin:0;color:var(--text-bright);font-family:var(--font-body);">\${n.name}</h3><span style="font-family:var(--font-mono);font-size:10px;padding:3px 9px;border-radius:100px;border:1px solid \${TCHS[n.type]};color:\${TCHS[n.type]};background:color-mix(in srgb,\${TCHS[n.type]} 10%,transparent);">\${n.type}</span></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;"><div style="font-size:13px;"><span style="font-family:var(--font-mono);font-size:11px;color:var(--text-dim);display:block;margin-bottom:4px;">External ID</span><code style="font-family:var(--font-mono);font-size:12px;background:var(--accent-dim);color:var(--accent-hi);padding:2px 6px;border-radius:4px;">\${n.extId}</code></div><div style="font-size:13px;"><span style="font-family:var(--font-mono);font-size:11px;color:var(--text-dim);display:block;margin-bottom:4px;">Confidence</span><strong style="color:\${TCHS[n.type]};font-family:var(--font-mono);">\${Math.round(n.confidence*100)}%</strong></div></div><p style="font-size:14px;color:var(--text-dim);margin-bottom:20px;">\${n.desc}</p><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;"><h4 style="font-size:1rem;margin:0;font-family:var(--font-body);">Relations</h4><span style="font-family:var(--font-mono);font-size:11px;color:\${TCHS[n.type]};">⇥ Traverse (2-hop)</span></div><div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;"><thead><tr><th style="padding:8px 12px;text-align:left;font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);border-bottom:1px solid var(--border-hi);background:var(--surface2);">Direction</th><th style="padding:8px 12px;text-align:left;font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);border-bottom:1px solid var(--border-hi);background:var(--surface2);">Relation</th><th style="padding:8px 12px;text-align:left;font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);border-bottom:1px solid var(--border-hi);background:var(--surface2);">Target</th><th style="padding:8px 12px;text-align:left;font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);border-bottom:1px solid var(--border-hi);background:var(--surface2);">Conf.</th></tr></thead><tbody>\${rows}</tbody></table></div>\`;
  document.getElementById('kg-dialog').style.display='block';
}
</script>

