<script type="importmap">{"imports":{"three":"https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js","three/addons/":"https://cdn.jsdelivr.net/npm/three@0.170.0/examples/jsm/"}}</script>
<script type="module">
import * as THREE from 'three';
import {OrbitControls} from 'three/addons/controls/OrbitControls.js';
import {EffectComposer} from 'three/addons/postprocessing/EffectComposer.js';
import {RenderPass} from 'three/addons/postprocessing/RenderPass.js';
import {UnrealBloomPass} from 'three/addons/postprocessing/UnrealBloomPass.js';
import {CSS2DRenderer,CSS2DObject} from 'three/addons/renderers/CSS2DRenderer.js';

const TCH={person:0xf97316,project:0x3b82f6,task:0x10b981,event:0xa78bfa,concept:0xe8a020,location:0xef4444,organization:0x06b6d4};
const TCHS={person:'#f97316',project:'#3b82f6',task:'#10b981',event:'#a78bfa',concept:'#e8a020',location:'#ef4444',organization:'#06b6d4'};

const entities=[
  {id:'e1',name:'GoClaw',type:'project',extId:'goclaw',desc:'Multi-tenant AI agent gateway',confidence:.95,p:[0,0,0]},
  {id:'e2',name:'Richard Ng',type:'person',extId:'richard-ng',desc:'Founder and CEO',confidence:.95,p:[-3,1,2]},
  {id:'e15',name:'NextLevel Builder',type:'organization',extId:'nextlevel-builder',desc:'Development organization',confidence:.9,p:[-5,0,-1]},
  {id:'e4',name:'Knowledge Graph',type:'concept',extId:'knowledge-graph',desc:'Semantic memory system',confidence:.92,p:[1,4,1]},
  {id:'e3',name:'Fox Spirit',type:'concept',extId:'fox-spirit',desc:'AI agent personality',confidence:.88,p:[-2,3,-1]},
  {id:'e10',name:'Agent Loop',type:'concept',extId:'agent-loop',desc:'Think-act-observe cycle',confidence:.88,p:[-4,3,1]},
  {id:'e11',name:'MCP Protocol',type:'concept',extId:'mcp-protocol',desc:'Model Context Protocol',confidence:.85,p:[4,3,-1]},
  {id:'e8',name:'Linh Nguyen',type:'person',extId:'linh-nguyen',desc:'Core team member',confidence:.82,p:[-4,-2,2]},
  {id:'e14',name:'Mitch Le',type:'person',extId:'mitch-le',desc:'Team member',confidence:.8,p:[-2,-2,-2]},
  {id:'e6',name:'Content Team',type:'organization',extId:'content-team',desc:'Marketing team',confidence:.8,p:[-1,-1,3]},
  {id:'e7',name:'GoClaw Desktop',type:'project',extId:'desktop-proj',desc:'Wails desktop edition',confidence:.88,p:[2,-4,0]},
  {id:'e5',name:'ClawBoxes',type:'project',extId:'clawboxes',desc:'Agent management',confidence:.85,p:[3,-1,3]},
  {id:'e13',name:'Security Audit',type:'task',extId:'security-audit',desc:'OWASP review',confidence:.82,p:[-3,2,-3]},
  {id:'e12',name:'Q2 Launch',type:'event',extId:'q2-launch',desc:'Product launch event',confidence:.78,p:[0,2,-3]},
  {id:'e19',name:'PR 218',type:'task',extId:'pr-218',desc:'Major PR merge',confidence:.8,p:[5,1,2]},
  {id:'e18',name:'Telegram',type:'concept',extId:'telegram-bot',desc:'Telegram channel',confidence:.85,p:[5,-1,-2]},
  {id:'e31',name:'WhatsApp',type:'concept',extId:'whatsapp',desc:'WhatsApp channel',confidence:.82,p:[4,-3,-1]},
  {id:'e9',name:'HCMC',type:'location',extId:'hcmc',desc:'Ho Chi Minh City',confidence:.9,p:[-2,-4,-1]},
  {id:'e34',name:'Singapore',type:'location',extId:'singapore',desc:'Regional office',confidence:.8,p:[-5,-3,-2]},
  {id:'e16',name:'SEO',type:'task',extId:'seo-opt',desc:'Search optimization',confidence:.75,p:[3,-4,2]},
  {id:'e17',name:'VN SMBs',type:'concept',extId:'vn-smbs',desc:'Target market',confidence:.78,p:[5,-4,0]},
];
const rels=[
  {s:'e2',t:'e1',tp:'FOUNDED'},{s:'e2',t:'e15',tp:'MANAGES'},{s:'e2',t:'e9',tp:'LOCATED_IN'},
  {s:'e2',t:'e6',tp:'MANAGES'},{s:'e2',t:'e12',tp:'ASSIGNED_TO'},{s:'e2',t:'e13',tp:'CREATED'},
  {s:'e1',t:'e4',tp:'IMPLEMENTS'},{s:'e1',t:'e3',tp:'USES'},{s:'e1',t:'e10',tp:'USES'},
  {s:'e1',t:'e11',tp:'INTEGRATES'},{s:'e1',t:'e18',tp:'INTEGRATES'},{s:'e5',t:'e1',tp:'PART_OF'},
  {s:'e7',t:'e1',tp:'VARIANT_OF'},{s:'e6',t:'e15',tp:'BELONGS_TO'},{s:'e8',t:'e15',tp:'WORKS_AT'},
  {s:'e8',t:'e2',tp:'REPORTS_TO'},{s:'e14',t:'e6',tp:'BELONGS_TO'},{s:'e14',t:'e2',tp:'REPORTS_TO'},
  {s:'e8',t:'e9',tp:'LOCATED_IN'},{s:'e19',t:'e1',tp:'RELATED_TO'},{s:'e16',t:'e17',tp:'TARGETS'},
];
const nMap=new Map(entities.map(e=>[e.id,e]));

const ctr=document.getElementById('kg3d');
const W=ctr.clientWidth, H=ctr.clientHeight;
const scene=new THREE.Scene();
scene.background=new THREE.Color(0x06090f);
scene.fog=new THREE.FogExp2(0x06090f,0.018);

const camera=new THREE.PerspectiveCamera(55,W/H,0.1,200);
camera.position.set(0,3,14);

const renderer=new THREE.WebGLRenderer({antialias:true});
renderer.setSize(W,H);
renderer.setPixelRatio(Math.min(devicePixelRatio,2));
renderer.toneMapping=THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure=1.1;
