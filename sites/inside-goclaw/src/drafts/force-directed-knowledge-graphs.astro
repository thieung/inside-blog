let currentLang = 'vi';

function setLang(lang) {
  currentLang = lang;
  document.documentElement.lang = lang;
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.toggle('active', b.dataset.lang === lang));
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.dataset.i18n;
    const val = T[lang]?.[key];
    if (val !== undefined) {
      el.innerHTML = val;
    }
  });
  // Update home links to preserve locale
  const homeHref = lang === 'vi' ? '/' : '/' + lang;
  document.querySelectorAll('a[href="/"], a[href="/en"], a[href="/zh"], a[href="/ja"], a[href="/en/"], a[href="/zh/"], a[href="/ja/"]').forEach(a => a.href = homeHref);
}

document.querySelectorAll('.lang-btn').forEach(btn => {
  btn.addEventListener('click', () => setLang(btn.dataset.lang));
});

// Detect lang from URL path (e.g. /en/posts/...) or query param (?lang=xx)
const pathMatch = window.location.pathname.match(/^\/(en|zh|ja)\//);
const urlLang = new URLSearchParams(window.location.search).get('lang');
const detectedLang = urlLang || (pathMatch && pathMatch[1]) || null;
if (detectedLang && ['vi','en','zh','ja'].includes(detectedLang)) setLang(detectedLang);
</script>

