<ScrollReveal />

<script>
  // Lang switcher
  function setLang(lang) {
    const path = window.location.pathname;
    const slug = 'pipeline-engine';
    const locales = ['en', 'zh', 'ja'];
    let base = path;
    for (const l of locales) {
      base = base.replace(`/${l}/`, '/').replace(`/${l}`, '/');
    }
    base = base.replace(/^\/posts\//, '/').replace(/^\/drafts\//, '/');
    let newPath;
    if (lang === 'vi') {
      newPath = `/drafts/${slug}`;
    } else {
      newPath = `/${lang}/posts/${slug}`;
    }
    window.location.href = newPath;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const langParam = params.get('lang');
    const locale = langParam || document.documentElement.lang || 'vi';
    document.querySelectorAll('.lang-btn').forEach(btn => {
      const l = btn.getAttribute('data-lang');
      if (l === locale) btn.classList.add('active');
      else btn.classList.remove('active');
      btn.addEventListener('click', () => setLang(l));
    });
  });
</script>

