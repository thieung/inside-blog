---
import statusData from '../../content/status.json';

// Compute counts at build time
const counts = { draft: 0, 'in-review': 0, approved: 0, 'needs-update': 0, published: 0 };
for (const entry of Object.values(statusData as Record<string, { status: string }>)) {
  const s = entry.status as keyof typeof counts;
  if (s in counts) counts[s]++;
}
const total = Object.values(counts).reduce((a, b) => a + b, 0);
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0f0f11; --surface: #18181b; --surface2: #222225; --border: #2e2e32;
      --text: #e4e4e7; --muted: #71717a; --dim: #52525b;
      --amber: #f59e0b; --green: #22c55e; --red: #ef4444; --blue: #3b82f6;
      --sans: 'Outfit', system-ui, sans-serif; --mono: 'JetBrains Mono', monospace;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--sans); background: var(--bg); color: var(--text); min-height: 100vh; }
    nav.admin-nav {
      padding: 0 32px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 0; height: 48px;
    }
    .brand { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--amber); margin-right: 32px; }
    .nav-item {
      padding: 0 16px; height: 48px; display: flex; align-items: center;
      font-family: var(--mono); font-size: 12px; color: var(--muted);
      text-decoration: none; border-bottom: 2px solid transparent; transition: color 0.15s;
    }
    .nav-item:hover { color: var(--text); }
    .nav-item.active { color: var(--amber); border-bottom-color: var(--amber); }
    .page { max-width: 960px; margin: 0 auto; padding: 40px 32px; }
    h1 { font-size: 24px; font-weight: 700; margin-bottom: 4px; }
    h1 span { color: var(--amber); }
    .subtitle { color: var(--muted); font-size: 14px; margin-bottom: 32px; }
    .stats-row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 40px; }
    .stat-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
      padding: 16px; display: flex; flex-direction: column; gap: 8px;
    }
    .stat-label { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--dim); }
    .stat-count { font-size: 28px; font-weight: 700; font-family: var(--mono); }
    .stat-count.draft { color: var(--amber); }
    .stat-count.in-review { color: var(--blue); }
    .stat-count.approved { color: var(--green); }
    .stat-count.needs-update { color: var(--red); }
    .stat-count.published { color: var(--muted); }
    .nav-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 40px; }
    .nav-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
      padding: 24px; text-decoration: none; color: var(--text); transition: border-color 0.15s;
      display: flex; flex-direction: column; gap: 8px;
    }
    .nav-card:hover { border-color: var(--amber); }
    .nav-card-icon { font-size: 24px; margin-bottom: 4px; }
    .nav-card-title { font-size: 16px; font-weight: 600; }
    .nav-card-desc { font-size: 13px; color: var(--muted); line-height: 1.5; }
    .nav-card-link { font-family: var(--mono); font-size: 11px; color: var(--amber); margin-top: 8px; }
    section.token-section {
      background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 24px;
    }
    .section-title { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--dim); margin-bottom: 16px; }
    .token-row { display: flex; gap: 12px; align-items: center; }
    .token-input {
      flex: 1; padding: 10px 14px; background: var(--bg); border: 1px solid var(--border);
      border-radius: 6px; color: var(--text); font-family: var(--mono); font-size: 13px; outline: none;
    }
    .token-input:focus { border-color: var(--amber); }
    .btn {
      padding: 10px 20px; border-radius: 6px; border: 1px solid var(--amber);
      background: transparent; color: var(--amber); font-family: var(--mono); font-size: 12px;
      cursor: pointer; transition: all 0.15s;
    }
    .btn:hover { background: var(--amber); color: #000; }
    .token-status { font-family: var(--mono); font-size: 11px; color: var(--dim); margin-top: 10px; }
  </style>
</head>
<body>
  <nav class="admin-nav">
    <span class="brand">GoClaw Admin</span>
    <a href="/admin" class="nav-item active">Dashboard</a>
    <a href="/admin/review" class="nav-item">Review</a>
    <a href="/admin/export" class="nav-item">Export</a>
    <a href="/admin/publish" class="nav-item">Publish</a>
  </nav>

  <div class="page">
    <h1>GoClaw Blog <span>Admin</span></h1>
    <p class="subtitle">Content management dashboard — {total} posts tracked</p>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-label">Draft</div>
        <div class="stat-count draft">{counts.draft}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">In Review</div>
        <div class="stat-count in-review">{counts['in-review']}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Approved</div>
        <div class="stat-count approved">{counts.approved}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Needs Update</div>
        <div class="stat-count needs-update">{counts['needs-update']}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Published</div>
        <div class="stat-count published">{counts.published}</div>
      </div>
    </div>

    <div class="nav-cards">
      <a href="/admin/review" class="nav-card">
        <div class="nav-card-icon">📝</div>
        <div class="nav-card-title">Review Drafts</div>
        <div class="nav-card-desc">Preview drafts in desktop/mobile, approve or flag for updates.</div>
        <div class="nav-card-link">→ /admin/review</div>
      </a>
      <a href="/admin/export" class="nav-card">
        <div class="nav-card-icon">📤</div>
        <div class="nav-card-title">Export Social</div>
        <div class="nav-card-desc">Preview thumbnails and copy social media text for each post.</div>
        <div class="nav-card-link">→ /admin/export</div>
      </a>
      <a href="/admin/publish" class="nav-card">
        <div class="nav-card-icon">🚀</div>
        <div class="nav-card-title">Publish</div>
        <div class="nav-card-desc">Create GitHub PRs for approved drafts to trigger publishing.</div>
        <div class="nav-card-link">→ /admin/publish</div>
      </a>
    </div>

    <section class="token-section">
      <div class="section-title">GitHub Token</div>
      <div class="token-row">
        <input type="password" class="token-input" id="tokenInput" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx" />
        <button class="btn" onclick="saveToken()">Save Token</button>
        <button class="btn" style="border-color:var(--dim);color:var(--dim)" onclick="clearToken()">Clear</button>
      </div>
      <div class="token-status" id="tokenStatus"></div>
    </section>
  </div>

  <script>
    const input = document.getElementById('tokenInput');
    const status = document.getElementById('tokenStatus');
    const stored = localStorage.getItem('gh-token');
    if (stored) {
      input.value = stored;
      status.textContent = 'Token saved — ' + stored.slice(0, 8) + '…';
      status.style.color = 'var(--green)';
    }
    function saveToken() {
      const val = input.value.trim();
      if (!val) return;
      localStorage.setItem('gh-token', val);
      status.textContent = 'Saved — ' + val.slice(0, 8) + '…';
      status.style.color = 'var(--green)';
    }
    function clearToken() {
      localStorage.removeItem('gh-token');
      input.value = '';
      status.textContent = 'Token cleared.';
      status.style.color = 'var(--dim)';
    }
  </script>
</body>
</html>
