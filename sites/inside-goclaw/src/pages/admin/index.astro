---
import statusData from '../../content/status.json';

// Get posts sorted by update date
const posts = Object.entries(statusData as Record<string, { status: string; updated: string }>)
  .map(([slug, meta]) => ({ slug, ...meta }))
  .sort((a, b) => b.updated.localeCompare(a.updated));

// Compute counts
const counts = { draft: 0, published: 0 };
for (const entry of Object.values(statusData as Record<string, { status: string }>)) {
  const s = entry.status as keyof typeof counts;
  if (s in counts) counts[s]++;
}
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GoClaw Admin — Social & Thumbnails</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0f0f11; --surface: #18181b; --surface2: #222225; --border: #2e2e32;
      --text: #e4e4e7; --muted: #71717a; --dim: #52525b;
      --amber: #f59e0b; --green: #22c55e; --red: #ef4444; --blue: #3b82f6;
      --sans: 'Outfit', system-ui, sans-serif; --mono: 'JetBrains Mono', monospace;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--sans); background: var(--bg); color: var(--text); min-height: 100vh; }

    /* Header */
    header {
      padding: 16px 32px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }
    .brand { font-family: var(--mono); font-size: 14px; font-weight: 600; color: var(--amber); }
    .stats { display: flex; gap: 16px; font-family: var(--mono); font-size: 12px; color: var(--muted); }
    .stat { display: flex; gap: 6px; align-items: center; }
    .stat-num { color: var(--text); font-weight: 600; }

    /* Toolbar */
    .toolbar {
      padding: 12px 32px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 16px; background: var(--surface);
    }
    .toolbar label { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--dim); }
    .toolbar select {
      font-family: var(--mono); font-size: 12px; padding: 6px 10px;
      border-radius: 6px; border: 1px solid var(--border);
      background: var(--bg); color: var(--text); cursor: pointer; outline: none;
    }
    .toolbar select:focus { border-color: var(--amber); }
    .sep { width: 1px; height: 24px; background: var(--border); }

    /* Main layout */
    .main { display: grid; grid-template-columns: 1fr 420px; height: calc(100vh - 105px); }

    /* Left panel - Social content */
    .social-panel { padding: 24px 32px; overflow-y: auto; }

    /* Platform tabs */
    .platform-tabs { display: flex; gap: 0; margin-bottom: 16px; border-radius: 8px; overflow: hidden; border: 1px solid var(--border); }
    .platform-tab {
      flex: 1; padding: 10px 16px; font-family: var(--mono); font-size: 11px;
      background: transparent; color: var(--dim); border: none; cursor: pointer;
      transition: all 0.15s; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .platform-tab:not(:last-child) { border-right: 1px solid var(--border); }
    .platform-tab:hover { color: var(--text); background: var(--surface); }
    .platform-tab.active { background: var(--surface2); color: var(--amber); }

    /* Content block */
    .content-block {
      background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
      margin-bottom: 16px; overflow: hidden;
    }
    .content-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 14px; background: var(--surface2); border-bottom: 1px solid var(--border);
    }
    .content-label { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--dim); }
    .copy-btn {
      font-family: var(--mono); font-size: 10px; padding: 4px 12px;
      border-radius: 4px; border: 1px solid var(--border);
      background: transparent; color: var(--dim); cursor: pointer; transition: all 0.2s;
    }
    .copy-btn:hover { border-color: var(--amber); color: var(--amber); }
    .copy-btn.copied { border-color: var(--green); color: var(--green); }
    .content-text {
      padding: 16px; font-family: var(--sans); font-size: 13px; color: var(--text);
      line-height: 1.7; white-space: pre-wrap; word-break: break-word;
      min-height: 120px; max-height: 300px; overflow-y: auto;
    }
    .empty-block { color: var(--dim); font-style: italic; }

    /* URL section */
    .url-section { margin-top: 16px; }
    .url-row { display: flex; gap: 8px; align-items: center; }
    .url-select {
      font-family: var(--mono); font-size: 11px; padding: 6px 10px;
      border-radius: 6px; border: 1px solid var(--border);
      background: var(--bg); color: var(--text); cursor: pointer;
    }
    .url-display {
      flex: 1; padding: 8px 12px; font-family: var(--mono); font-size: 11px;
      background: var(--surface); border: 1px solid var(--border); border-radius: 6px;
      color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    /* Right panel - Thumbnail */
    .thumb-panel { border-left: 1px solid var(--border); display: flex; flex-direction: column; }
    .thumb-header {
      padding: 12px 16px; border-bottom: 1px solid var(--border);
      font-family: var(--mono); font-size: 10px; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--dim); background: var(--surface);
    }
    .thumb-wrap {
      flex: 1; display: flex; align-items: center; justify-content: center;
      background: #000; overflow: hidden; padding: 16px;
    }
    .thumb-scaler { position: relative; transition: transform 0.2s; }
    .thumb-scaler iframe { border: none; display: block; }
    .no-thumb { color: var(--dim); font-family: var(--mono); font-size: 12px; text-align: center; }

    .hidden { display: none !important; }
  </style>
</head>
<body>
  <header>
    <span class="brand">GoClaw Admin</span>
    <div class="stats">
      <span class="stat"><span class="stat-num">{counts.published}</span> published</span>
      <span class="stat"><span class="stat-num">{counts.draft}</span> drafts</span>
    </div>
  </header>

  <div class="toolbar">
    <label>Post</label>
    <select id="postSel">
      {posts.map(p => <option value={p.slug}>{p.slug}</option>)}
    </select>
  </div>

  <div class="main">
    <!-- Left: Social Content -->
    <div class="social-panel">
      <div class="platform-tabs">
        <button class="platform-tab active" data-platform="facebook">Facebook</button>
        <button class="platform-tab" data-platform="threads">Threads</button>
        <button class="platform-tab" data-platform="x">X / Twitter</button>
        <button class="platform-tab" data-platform="linkedin">LinkedIn</button>
      </div>

      <div class="content-block">
        <div class="content-head">
          <span class="content-label" id="platformLabel">Facebook Post</span>
          <button class="copy-btn" id="copyBtn">Copy</button>
        </div>
        <pre class="content-text" id="contentText"><span class="empty-block">Select a post to view content</span></pre>
      </div>

      <div class="url-section">
        <div class="content-head" style="border-radius: 8px 8px 0 0; border: 1px solid var(--border); border-bottom: none;">
          <span class="content-label">Post URL</span>
          <button class="copy-btn" id="copyUrlBtn">Copy URL</button>
        </div>
        <div class="url-row" style="background: var(--surface); padding: 12px; border: 1px solid var(--border); border-radius: 0 0 8px 8px;">
          <select class="url-select" id="urlLangSel">
            <option value="vi">Vietnamese</option>
            <option value="en">English</option>
            <option value="zh">Chinese</option>
            <option value="ja">Japanese</option>
          </select>
          <div class="url-display" id="urlDisplay">—</div>
        </div>
      </div>
    </div>

    <!-- Right: Thumbnail -->
    <div class="thumb-panel">
      <div class="thumb-header">Thumbnail Preview</div>
      <div class="thumb-wrap" id="thumbWrap">
        <div class="no-thumb">Select a post with thumbnail</div>
      </div>
    </div>
  </div>

  <script>
    const postSel = document.getElementById('postSel');
    const platformTabs = document.querySelectorAll('.platform-tab');
    const platformLabel = document.getElementById('platformLabel');
    const contentText = document.getElementById('contentText');
    const copyBtn = document.getElementById('copyBtn');
    const urlLangSel = document.getElementById('urlLangSel');
    const urlDisplay = document.getElementById('urlDisplay');
    const copyUrlBtn = document.getElementById('copyUrlBtn');
    const thumbWrap = document.getElementById('thumbWrap');

    let currentPlatform = 'facebook';
    let socialData = null;

    const platformLabels = {
      facebook: 'Facebook Post',
      threads: 'Threads Post',
      x: 'X / Twitter Post',
      linkedin: 'LinkedIn Post'
    };

    // Platform tab click
    platformTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        platformTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        currentPlatform = tab.dataset.platform;
        platformLabel.textContent = platformLabels[currentPlatform];
        renderContent();
      });
    });

    // Load social content
    async function loadSocialContent(slug) {
      try {
        const res = await fetch(`/social/${slug}/content.json`);
        if (!res.ok) {
          socialData = null;
          return;
        }
        socialData = await res.json();
      } catch {
        socialData = null;
      }
    }

    // Render content for current platform
    function renderContent() {
      if (!socialData || !socialData.posts || !socialData.posts[currentPlatform]) {
        contentText.innerHTML = '<span class="empty-block">No content available</span>';
        return;
      }
      contentText.textContent = socialData.posts[currentPlatform].content;
    }

    // Render URL
    function renderUrl() {
      const slug = postSel.value;
      const lang = urlLangSel.value;
      const baseUrl = 'https://goclaw.thieunv.space';

      if (socialData && socialData.urls && socialData.urls[lang]) {
        urlDisplay.textContent = socialData.urls[lang];
      } else {
        // Fallback URL construction
        const prefix = lang === 'vi' ? '' : `/${lang}`;
        urlDisplay.textContent = `${baseUrl}${prefix}/posts/${slug}`;
      }
    }

    // Load thumbnail
    function loadThumbnail(slug) {
      const thumbSrc = `/social/${slug}/thumbnail.html`;

      thumbWrap.innerHTML = '<div class="no-thumb">Loading...</div>';

      // Check if thumbnail exists
      fetch(thumbSrc, { method: 'HEAD' })
        .then(res => {
          if (!res.ok) {
            thumbWrap.innerHTML = '<div class="no-thumb">No thumbnail available</div>';
            return;
          }

          const W = 1200, H = 630;
          const panelW = thumbWrap.clientWidth - 32;
          const panelH = thumbWrap.clientHeight - 32;
          const scale = Math.min(panelW / W, panelH / H, 1);

          thumbWrap.innerHTML = `
            <div class="thumb-scaler" style="width:${W * scale}px;height:${H * scale}px">
              <iframe src="${thumbSrc}" style="width:${W}px;height:${H}px;transform:scale(${scale});transform-origin:top left;border:none"></iframe>
            </div>
          `;
        })
        .catch(() => {
          thumbWrap.innerHTML = '<div class="no-thumb">No thumbnail available</div>';
        });
    }

    // Load all data for a post
    async function loadPost() {
      const slug = postSel.value;
      if (!slug) return;

      await loadSocialContent(slug);
      renderContent();
      renderUrl();
      loadThumbnail(slug);
    }

    // Copy content
    copyBtn.addEventListener('click', () => {
      const text = contentText.textContent;
      if (!text || text.includes('No content')) return;

      navigator.clipboard.writeText(text).then(() => {
        copyBtn.textContent = 'Copied!';
        copyBtn.classList.add('copied');
        setTimeout(() => {
          copyBtn.textContent = 'Copy';
          copyBtn.classList.remove('copied');
        }, 2000);
      });
    });

    // Copy URL
    copyUrlBtn.addEventListener('click', () => {
      const url = urlDisplay.textContent;
      if (!url || url === '—') return;

      navigator.clipboard.writeText(url).then(() => {
        copyUrlBtn.textContent = 'Copied!';
        copyUrlBtn.classList.add('copied');
        setTimeout(() => {
          copyUrlBtn.textContent = 'Copy URL';
          copyUrlBtn.classList.remove('copied');
        }, 2000);
      });
    });

    // Event listeners
    postSel.addEventListener('change', loadPost);
    urlLangSel.addEventListener('change', renderUrl);

    // Initial load
    loadPost();
  </script>
</body>
</html>
