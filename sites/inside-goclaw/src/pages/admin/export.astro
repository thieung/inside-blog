---
import statusData from '../../content/status.json';

const posts = Object.entries(statusData as Record<string, { status: string; updated: string }>)
  .map(([slug, meta]) => ({ slug, ...meta }))
  .sort((a, b) => b.updated.localeCompare(a.updated));
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Export Social</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0f0f11; --surface: #18181b; --surface2: #222225; --border: #2e2e32;
      --text: #e4e4e7; --muted: #71717a; --dim: #52525b;
      --amber: #f59e0b; --green: #22c55e; --red: #ef4444; --blue: #3b82f6;
      --sans: 'Outfit', system-ui, sans-serif; --mono: 'JetBrains Mono', monospace;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--sans); background: var(--bg); color: var(--text); min-height: 100vh; }
    nav.admin-nav {
      padding: 0 32px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; height: 48px;
    }
    .brand { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--amber); margin-right: 32px; }
    .nav-item {
      padding: 0 16px; height: 48px; display: flex; align-items: center;
      font-family: var(--mono); font-size: 12px; color: var(--muted);
      text-decoration: none; border-bottom: 2px solid transparent; transition: color 0.15s;
    }
    .nav-item:hover { color: var(--text); }
    .nav-item.active { color: var(--amber); border-bottom-color: var(--amber); }
    .toolbar {
      padding: 12px 32px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 16px; background: var(--surface);
    }
    .toolbar label { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--dim); }
    .toolbar select {
      font-family: var(--mono); font-size: 12px; padding: 6px 10px;
      border-radius: 6px; border: 1px solid var(--border);
      background: var(--bg); color: var(--text); cursor: pointer; outline: none;
    }
    .toolbar select:focus { border-color: var(--amber); }
    .sep { width: 1px; height: 24px; background: var(--border); }
    .lang-btns { display: flex; border-radius: 6px; overflow: hidden; border: 1px solid var(--border); }
    .lang-btn {
      padding: 5px 14px; font-family: var(--mono); font-size: 11px;
      background: transparent; color: var(--dim); border: none; cursor: pointer; transition: all 0.15s;
    }
    .lang-btn.active { background: var(--surface2); color: var(--text); }
    .page { display: grid; grid-template-columns: 1fr 380px; gap: 0; height: calc(100vh - 48px - 57px); }
    .social-panel { padding: 24px 32px; overflow-y: auto; }
    .content-block {
      background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
      margin-bottom: 14px; overflow: hidden;
    }
    .content-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 14px; background: var(--surface2); border-bottom: 1px solid var(--border);
    }
    .content-label { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--dim); }
    .copy-btn {
      font-family: var(--mono); font-size: 10px; padding: 3px 10px;
      border-radius: 4px; border: 1px solid var(--border);
      background: transparent; color: var(--dim); cursor: pointer; transition: all 0.2s;
    }
    .copy-btn:hover { border-color: var(--amber); color: var(--amber); }
    .copy-btn.copied { border-color: var(--green); color: var(--green); }
    .content-text {
      padding: 14px; font-family: var(--sans); font-size: 13px; color: var(--text);
      line-height: 1.7; white-space: pre-wrap; word-break: break-word;
    }
    .empty-block { color: var(--dim); font-style: italic; }
    .preview-panel { border-left: 1px solid var(--border); display: flex; flex-direction: column; }
    .preview-header {
      padding: 10px 16px; border-bottom: 1px solid var(--border);
      font-family: var(--mono); font-size: 10px; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--dim); background: var(--surface);
    }
    .preview-wrap {
      flex: 1; display: flex; align-items: center; justify-content: center;
      background: #000; overflow: hidden; padding: 16px;
    }
    .preview-scaler { position: relative; }
    .preview-scaler iframe { border: none; display: block; transform-origin: top left; }
    .no-thumb {
      color: var(--dim); font-family: var(--mono); font-size: 12px; text-align: center;
    }
  </style>
</head>
<body>
  <nav class="admin-nav">
    <span class="brand">GoClaw Admin</span>
    <a href="/admin" class="nav-item">Dashboard</a>
    <a href="/admin/review" class="nav-item">Review</a>
    <a href="/admin/export" class="nav-item active">Export</a>
    <a href="/admin/publish" class="nav-item">Publish</a>
  </nav>

  <div class="toolbar">
    <label>Post</label>
    <select id="postSel">
      {posts.map(p => <option value={p.slug}>{p.slug} ({p.status})</option>)}
    </select>
    <div class="sep"></div>
    <label>Lang</label>
    <div class="lang-btns">
      <button class="lang-btn active" data-lang="vi" onclick="setLang('vi')">VI</button>
      <button class="lang-btn" data-lang="en" onclick="setLang('en')">EN</button>
    </div>
  </div>

  <div class="page">
    <div class="social-panel">
      <div class="content-block">
        <div class="content-head">
          <span class="content-label">Facebook Post</span>
          <button class="copy-btn" id="copyFb" onclick="copyBlock('fbText','copyFb')">Copy</button>
        </div>
        <pre class="content-text" id="fbText">Loading…</pre>
      </div>
      <div class="content-block">
        <div class="content-head">
          <span class="content-label">Facebook Comment</span>
          <button class="copy-btn" id="copyFbC" onclick="copyBlock('fbCommentText','copyFbC')">Copy</button>
        </div>
        <pre class="content-text" id="fbCommentText">Loading…</pre>
      </div>
      <div class="content-block">
        <div class="content-head">
          <span class="content-label">X / Twitter</span>
          <button class="copy-btn" id="copyX" onclick="copyBlock('xText','copyX')">Copy</button>
        </div>
        <pre class="content-text" id="xText">Loading…</pre>
      </div>
      <div class="content-block">
        <div class="content-head">
          <span class="content-label">Threads</span>
          <button class="copy-btn" id="copyTh" onclick="copyBlock('threadsText','copyTh')">Copy</button>
        </div>
        <pre class="content-text" id="threadsText">Loading…</pre>
      </div>
    </div>

    <div class="preview-panel">
      <div class="preview-header">Thumbnail Preview (1200×630)</div>
      <div class="preview-wrap" id="previewWrap">
        <div class="no-thumb">No thumbnail</div>
      </div>
    </div>
  </div>

  <script>
    let currentLang = 'vi';
    const postSel = document.getElementById('postSel');

    function setLang(lang) {
      currentLang = lang;
      document.querySelectorAll('.lang-btn').forEach(b => b.classList.toggle('active', b.dataset.lang === lang));
      load();
    }
    window.setLang = setLang;

    async function fetchText(url) {
      try {
        const r = await fetch(url);
        return r.ok ? (await r.text()).trim() : null;
      } catch { return null; }
    }

    function setBlock(id, text) {
      const el = document.getElementById(id);
      if (text) {
        el.textContent = text;
        el.classList.remove('empty-block');
      } else {
        el.textContent = 'Not available';
        el.classList.add('empty-block');
      }
    }

    async function load() {
      const slug = postSel.value;
      const base = `/social/${slug}`;

      const [fb, fbC, x, threads] = await Promise.all([
        fetchText(`${base}/facebook-post.txt`),
        fetchText(`${base}/facebook-comment.txt`),
        fetchText(`${base}/x-post.txt`),
        fetchText(`${base}/threads-post.txt`),
      ]);
      setBlock('fbText', fb);
      setBlock('fbCommentText', fbC);
      setBlock('xText', x);
      setBlock('threadsText', threads);

      // Thumbnail preview — scale to fit 380px wide panel
      const wrap = document.getElementById('previewWrap');
      const thumbSrc = `${base}/thumbnail-${currentLang}.html`;
      const W = 1200, H = 630;
      const panelW = wrap.clientWidth - 32;
      const scale = Math.min(panelW / W, (wrap.clientHeight - 32) / H, 1);
      wrap.innerHTML = `<div class="preview-scaler" style="width:${W*scale}px;height:${H*scale}px">
        <iframe src="${thumbSrc}" style="width:${W}px;height:${H}px;transform:scale(${scale});transform-origin:top left"></iframe>
      </div>`;
    }

    function copyBlock(textId, btnId) {
      const text = document.getElementById(textId).textContent;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById(btnId);
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
      });
    }
    window.copyBlock = copyBlock;

    postSel.addEventListener('change', load);
    load();
  </script>
</body>
</html>
