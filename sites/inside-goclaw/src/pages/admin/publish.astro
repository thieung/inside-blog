---
import statusData from '../../content/status.json';

const approved = Object.entries(statusData as Record<string, { status: string; updated: string }>)
  .filter(([, meta]) => meta.status === 'approved')
  .map(([slug, meta]) => ({ slug, ...meta }))
  .sort((a, b) => b.updated.localeCompare(a.updated));
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Publish</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0f0f11; --surface: #18181b; --surface2: #222225; --border: #2e2e32;
      --text: #e4e4e7; --muted: #71717a; --dim: #52525b;
      --amber: #f59e0b; --green: #22c55e; --red: #ef4444; --blue: #3b82f6;
      --sans: 'Outfit', system-ui, sans-serif; --mono: 'JetBrains Mono', monospace;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--sans); background: var(--bg); color: var(--text); min-height: 100vh; }
    nav.admin-nav {
      padding: 0 32px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; height: 48px;
    }
    .brand { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--amber); margin-right: 32px; }
    .nav-item {
      padding: 0 16px; height: 48px; display: flex; align-items: center;
      font-family: var(--mono); font-size: 12px; color: var(--muted);
      text-decoration: none; border-bottom: 2px solid transparent; transition: color 0.15s;
    }
    .nav-item:hover { color: var(--text); }
    .nav-item.active { color: var(--amber); border-bottom-color: var(--amber); }
    .page { max-width: 800px; margin: 0 auto; padding: 40px 32px; }
    h1 { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
    h1 span { color: var(--amber); }
    .subtitle { color: var(--muted); font-size: 14px; margin-bottom: 32px; }
    /* Config */
    .config-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
      padding: 20px; margin-bottom: 28px;
    }
    .config-title { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--dim); margin-bottom: 14px; }
    .config-row { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
    .cfg-label { font-family: var(--mono); font-size: 11px; color: var(--dim); white-space: nowrap; }
    .cfg-input {
      flex: 1; min-width: 140px; padding: 8px 12px; background: var(--bg);
      border: 1px solid var(--border); border-radius: 6px; color: var(--text);
      font-family: var(--mono); font-size: 12px; outline: none;
    }
    .cfg-input:focus { border-color: var(--amber); }
    .sep-v { width: 1px; height: 20px; background: var(--border); }
    /* Draft list */
    .section-title { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--dim); margin-bottom: 14px; }
    .draft-row {
      background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
      padding: 16px 20px; margin-bottom: 10px;
      display: flex; align-items: center; gap: 16px;
    }
    .draft-info { flex: 1; min-width: 0; }
    .draft-slug { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--text); }
    .draft-date { font-family: var(--mono); font-size: 11px; color: var(--dim); margin-top: 3px; }
    .badge-approved { background: rgba(34,197,94,0.12); color: var(--green); font-family: var(--mono); font-size: 10px; padding: 2px 10px; border-radius: 4px; }
    .publish-btn {
      padding: 8px 18px; border-radius: 6px; border: 1px solid var(--amber);
      background: transparent; color: var(--amber); font-family: var(--mono); font-size: 11px;
      cursor: pointer; transition: all 0.15s; white-space: nowrap;
    }
    .publish-btn:hover { background: var(--amber); color: #000; }
    .publish-btn:disabled { opacity: 0.4; cursor: default; }
    .pr-link { font-family: var(--mono); font-size: 11px; color: var(--blue); text-decoration: none; }
    .pr-link:hover { text-decoration: underline; }
    .empty-state { color: var(--dim); font-size: 14px; padding: 40px 0; text-align: center; }
    /* Modal */
    .modal-backdrop {
      position: fixed; inset: 0; background: rgba(0,0,0,0.7);
      display: flex; align-items: center; justify-content: center; z-index: 100;
    }
    .modal-backdrop.hidden { display: none; }
    .modal {
      background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
      padding: 28px; width: 440px; max-width: 90vw;
    }
    .modal-title { font-size: 16px; font-weight: 600; margin-bottom: 10px; }
    .modal-body { font-size: 14px; color: var(--muted); margin-bottom: 20px; line-height: 1.6; }
    .modal-body code { font-family: var(--mono); color: var(--text); font-size: 12px; }
    .modal-btns { display: flex; gap: 10px; justify-content: flex-end; }
    .btn-cancel {
      padding: 8px 18px; border-radius: 6px; border: 1px solid var(--border);
      background: transparent; color: var(--muted); font-family: var(--mono); font-size: 12px; cursor: pointer;
    }
    .btn-cancel:hover { color: var(--text); }
    .btn-confirm {
      padding: 8px 18px; border-radius: 6px; border: none;
      background: var(--amber); color: #000; font-family: var(--mono); font-size: 12px;
      font-weight: 600; cursor: pointer; transition: opacity 0.15s;
    }
    .btn-confirm:hover { opacity: 0.85; }
    .btn-confirm:disabled { opacity: 0.4; cursor: default; }
    .status-msg { font-family: var(--mono); font-size: 11px; margin-top: 10px; }
    .status-msg.error { color: var(--red); }
    .status-msg.ok { color: var(--green); }
  </style>
</head>
<body>
  <nav class="admin-nav">
    <span class="brand">GoClaw Admin</span>
    <a href="/admin" class="nav-item">Dashboard</a>
    <a href="/admin/review" class="nav-item">Review</a>
    <a href="/admin/export" class="nav-item">Export</a>
    <a href="/admin/publish" class="nav-item active">Publish</a>
  </nav>

  <div class="page">
    <h1>Publish <span>Workflow</span></h1>
    <p class="subtitle">Create GitHub PRs for approved drafts.</p>

    <div class="config-card">
      <div class="config-title">GitHub Config</div>
      <div class="config-row">
        <span class="cfg-label">Owner</span>
        <input class="cfg-input" id="cfgOwner" placeholder="nextlevelbuilder" />
        <div class="sep-v"></div>
        <span class="cfg-label">Repo</span>
        <input class="cfg-input" id="cfgRepo" placeholder="goclaw-blog" />
        <div class="sep-v"></div>
        <span class="cfg-label">Base branch</span>
        <input class="cfg-input" id="cfgBase" placeholder="main" style="max-width:100px" />
      </div>
    </div>

    <div class="section-title">
      Approved Drafts ({approved.length})
    </div>

    {approved.length === 0 ? (
      <div class="empty-state">No approved drafts. Go to Review to approve drafts first.</div>
    ) : (
      <div id="draftList">
        {approved.map(p => (
          <div class="draft-row" id={`row-${p.slug}`}>
            <div class="draft-info">
              <div class="draft-slug">{p.slug}</div>
              <div class="draft-date">Approved · updated {p.updated}</div>
            </div>
            <span class="badge-approved">approved</span>
            <button class="publish-btn" onclick={`openModal('${p.slug}')`}>Publish →</button>
            <span id={`pr-${p.slug}`}></span>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Confirmation modal -->
  <div class="modal-backdrop hidden" id="modalBackdrop">
    <div class="modal">
      <div class="modal-title">Confirm Publish</div>
      <div class="modal-body" id="modalBody"></div>
      <div class="status-msg" id="modalStatus"></div>
      <div class="modal-btns">
        <button class="btn-cancel" onclick="closeModal()">Cancel</button>
        <button class="btn-confirm" id="btnConfirm" onclick="confirmPublish()">Create PR</button>
      </div>
    </div>
  </div>

  <script>
    // Restore config from localStorage
    const cfgOwner = document.getElementById('cfgOwner');
    const cfgRepo = document.getElementById('cfgRepo');
    const cfgBase = document.getElementById('cfgBase');
    cfgOwner.value = localStorage.getItem('gh-owner') || 'nextlevelbuilder';
    cfgRepo.value = localStorage.getItem('gh-repo') || 'goclaw-blog';
    cfgBase.value = localStorage.getItem('gh-base') || 'main';
    [cfgOwner, cfgRepo, cfgBase].forEach(el => {
      el.addEventListener('change', () => {
        localStorage.setItem('gh-owner', cfgOwner.value.trim());
        localStorage.setItem('gh-repo', cfgRepo.value.trim());
        localStorage.setItem('gh-base', cfgBase.value.trim());
      });
    });

    let pendingSlug = null;

    function openModal(slug) {
      pendingSlug = slug;
      document.getElementById('modalBody').innerHTML =
        `Create a pull request to publish <code>${slug}</code>?<br><br>` +
        `This will call the GitHub API using your saved token to open a PR from a <code>publish/${slug}</code> branch into <code>${cfgBase.value || 'main'}</code>.`;
      document.getElementById('modalStatus').textContent = '';
      document.getElementById('modalStatus').className = 'status-msg';
      document.getElementById('btnConfirm').disabled = false;
      document.getElementById('modalBackdrop').classList.remove('hidden');
    }
    window.openModal = openModal;

    function closeModal() {
      document.getElementById('modalBackdrop').classList.add('hidden');
      pendingSlug = null;
    }
    window.closeModal = closeModal;

    async function confirmPublish() {
      const slug = pendingSlug;
      if (!slug) return;

      const token = localStorage.getItem('gh-token') || '';
      const owner = cfgOwner.value.trim() || 'nextlevelbuilder';
      const repo = cfgRepo.value.trim() || 'goclaw-blog';
      const base = cfgBase.value.trim() || 'main';
      const head = `publish/${slug}`;

      if (!token) {
        showStatus('No GitHub token found. Save one on the Dashboard page.', 'error');
        return;
      }

      const btn = document.getElementById('btnConfirm');
      btn.disabled = true;
      showStatus('Creating PR…', '');

      try {
        const res = await fetch(`https://api.github.com/repos/${owner}/${repo}/pulls`, {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${token}`,
            Accept: 'application/vnd.github.v3+json',
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            title: `publish: ${slug}`,
            head,
            base,
            body: `Publishing draft \`${slug}\` to the blog.\n\nApproved via GoClaw Blog Admin.`,
          }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ message: res.statusText }));
          throw new Error(err.message || `HTTP ${res.status}`);
        }

        const data = await res.json();
        const prUrl = data.html_url;

        showStatus('PR created!', 'ok');
        setTimeout(() => {
          closeModal();
          // Show PR link inline
          const linkEl = document.getElementById(`pr-${slug}`);
          if (linkEl) {
            linkEl.innerHTML = `<a class="pr-link" href="${prUrl}" target="_blank" rel="noopener">→ PR #${data.number}</a>`;
          }
          // Disable publish button
          const rowBtn = document.querySelector(`#row-${slug} .publish-btn`);
          if (rowBtn) { rowBtn.disabled = true; rowBtn.textContent = 'PR created'; }
        }, 1200);
      } catch (err) {
        showStatus('Error: ' + err.message, 'error');
        btn.disabled = false;
      }
    }
    window.confirmPublish = confirmPublish;

    function showStatus(msg, type) {
      const el = document.getElementById('modalStatus');
      el.textContent = msg;
      el.className = 'status-msg' + (type ? ' ' + type : '');
    }

    // Close modal on backdrop click
    document.getElementById('modalBackdrop').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeModal();
    });
  </script>
</body>
</html>
